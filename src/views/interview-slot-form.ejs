<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Nuevo slot de entrevista — LoginPro</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: system-ui, sans-serif; font-size: 14px; background: #f5f5f5; color: #1a1a1a; }
    .topbar { background: #1a1a2e; color: #fff; padding: 12px 24px; display: flex; align-items: center; gap: 16px; }
    .topbar a { color: #a0c4ff; text-decoration: none; font-size: 13px; }
    h1 { font-size: 18px; font-weight: 600; color: #fff; }
    .container { max-width: 560px; margin: 32px auto; padding: 0 24px; }
    .card { background: #fff; border: 1px solid #e0e0e0; border-radius: 10px; padding: 28px 32px; }
    h2 { font-size: 16px; font-weight: 700; margin-bottom: 24px; color: #1a1a2e; }
    .field { margin-bottom: 18px; }
    label { display: block; font-size: 12px; font-weight: 700; color: #555; margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.04em; }
    input, select, textarea { width: 100%; padding: 9px 12px; border: 1px solid #d0d0d0; border-radius: 6px; font-size: 14px; background: #fafafa; }
    input:focus, select:focus, textarea:focus { outline: none; border-color: #4f46e5; background: #fff; }
    textarea { resize: vertical; min-height: 72px; }
    .hint { font-size: 11px; color: #888; margin-top: 4px; }
    .actions { display: flex; gap: 10px; margin-top: 24px; }
    .btn { padding: 9px 20px; border-radius: 6px; font-size: 14px; font-weight: 600; cursor: pointer; text-decoration: none; border: none; }
    .btn-primary { background: #1a1a2e; color: #fff; }
    .btn-primary:hover { background: #2e2e4e; }
    .btn-outline { background: transparent; color: #555; border: 1px solid #ccc; }
    .btn-outline:hover { background: #f0f0f0; }
    .row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  </style>
</head>
<body>
  <div class="topbar">
    <h1>LoginPro · Nuevo slot</h1>
    <a href="/admin/interview-slots">← Volver a slots</a>
    <a href="/logout" style="margin-left:auto;">Salir</a>
  </div>

  <div class="container">
    <div class="card">
      <h2>Crear slot de entrevista</h2>
      <form method="POST" action="/admin/interview-slots">

        <div class="field">
          <label for="vacancyId">Vacante *</label>
          <select name="vacancyId" id="vacancyId" required>
            <option value="">Selecciona una vacante</option>
            <% vacancies.forEach(v => { %>
              <option value="<%= v.id %>" <%= preselectedVacancyId === v.id ? 'selected' : '' %>>
                <%= v.title %> (<%= v.key %>)
              </option>
            <% }); %>
          </select>
        </div>

        <div class="row">
          <div class="field">
            <label for="scheduledAt">Fecha y hora *</label>
            <input type="datetime-local" name="scheduledAt" id="scheduledAt" required
                   min="<%= new Date().toISOString().slice(0, 16) %>">
            <div class="hint">Hora de Bogotá (UTC-5)</div>
          </div>
          <div class="field">
            <label for="capacity">Capacidad (personas)</label>
            <input type="number" name="capacity" id="capacity" value="1" min="1" max="50">
          </div>
        </div>

        <div class="field">
          <label for="location">Lugar / dirección</label>
          <input type="text" name="location" id="location" placeholder="Ej: Carrera 15 #93-75, piso 3">
        </div>

        <div class="field">
          <label for="expiresMinutes">Cierre de agendamiento (minutos antes)</label>
          <input type="number" name="expiresMinutes" id="expiresMinutes" value="60" min="10" max="1440">
          <div class="hint">El slot dejará de ofrecerse a candidatos este tiempo antes de la cita.</div>
        </div>

        <div class="field">
          <label for="notes">Notas internas</label>
          <textarea name="notes" id="notes" placeholder="Información adicional para el equipo (no se muestra al candidato)"></textarea>
        </div>

        <div class="actions">
          <button type="submit" class="btn btn-primary">Crear slot</button>
          <a href="/admin/interview-slots<%= preselectedVacancyId ? '?vacancyId=' + encodeURIComponent(preselectedVacancyId) : '' %>" class="btn btn-outline">Cancelar</a>
        </div>
      </form>
    </div>
  </div>
</body>
</html>
