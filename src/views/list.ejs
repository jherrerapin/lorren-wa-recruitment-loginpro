        <% if (!isToday) { %>
          <%
            const todayParams = new URLSearchParams();
            if (activeCity) todayParams.set('city', activeCity);
            if (todayStr) todayParams.set('date', todayStr);
            appendVacancyFilters(todayParams);
            appendVacancySearches(todayParams);
