      <a href="/admin?status=all<%= candidateSearch?.field ? '&searchField=' + encodeURIComponent(candidateSearch.field) : '' %><%= candidateSearch?.text ? '&searchText=' + encodeURIComponent(candidateSearch.text) : '' %>" class="export-btn">Ver todos</a>
