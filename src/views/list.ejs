<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Panel de Reclutamiento — LoginPro</title>
  <link rel="icon" type="image/png" href="/public/favicon-loginpro.svg" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:           #f4f5f7;
      --surface:      #ffffff;
      --surface-2:    #f9fafb;
      --border:       #e1e4e8;
      --border-soft:  #eaecef;
      --text:         #1a1d23;
      --text-muted:   #6b7280;
      --text-faint:   #9ca3af;
      --navy:         #1e2d3d;
      --navy-hover:   #162330;
      --teal:         #0d7a6b;
      --teal-light:   #e6f4f1;
      --teal-hover:   #0a5f53;
      --amber:        #b45309;
      --amber-light:  #fef3c7;
      --red:          #dc2626;
      --red-light:    #fee2e2;
      --gray-light:   #f3f4f6;
      --green:        #16a34a;
      --green-light:  #dcfce7;
      --blue:         #1d4ed8;
      --blue-light:   #dbeafe;
      --purple:       #7c3aed;
      --purple-light: #ede9fe;
      --shadow-sm:    0 1px 3px rgba(0,0,0,.08);
      --shadow-md:    0 4px 12px rgba(0,0,0,.10);
      --radius:       8px;
      --radius-lg:    12px;
      --font: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }

    body { font-family: var(--font); background: var(--bg); color: var(--text); font-size: 14px; line-height: 1.5; }

    /* ── Navbar ── */
    .navbar {
      background: var(--navy); padding: 0 24px; display: flex;
      align-items: center; gap: 20px; height: 52px; position: sticky; top: 0; z-index: 100;
      box-shadow: 0 2px 8px rgba(0,0,0,.2);
    }
    .navbar a { color: #cbd5e0; text-decoration: none; font-size: 13px; font-weight: 500; padding: 4px 2px; border-bottom: 2px solid transparent; transition: color .15s, border-color .15s; }
    .navbar a:hover { color: #fff; border-bottom-color: rgba(255,255,255,.3); }
    .navbar a.nav-active { color: #fff; border-bottom-color: #4fd1c5; }
    .navbar .brand img { height: 28px; display: block; }
    .navbar .spacer { flex: 1; }
    .btn-logout { background: transparent; border: 1px solid rgba(255,255,255,.25); color: #cbd5e0 !important; padding: 5px 12px !important; border-radius: 6px; cursor: pointer; font-size: 12px; font-weight: 500; transition: all .15s; }
    .btn-logout:hover { border-color: rgba(255,255,255,.6) !important; color: #fff !important; }

    /* ── Layout ── */
    .page { max-width: 1280px; margin: 0 auto; padding: 24px 20px 48px; }

    /* ── Page header ── */
    .page-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; margin-bottom: 24px; flex-wrap: wrap; }
    .page-header h1 { font-size: 20px; font-weight: 700; color: var(--navy); }
    .page-header .sub { font-size: 13px; color: var(--text-muted); margin-top: 2px; }
    .header-metrics {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }
    .metric-pill {
      display: inline-flex;
      flex-direction: column;
      gap: 2px;
      min-width: 180px;
      padding: 10px 14px;
      border-radius: var(--radius);
      border: 1px solid var(--border);
      background: var(--surface);
      box-shadow: var(--shadow-sm);
    }
    .metric-pill-label {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .05em;
      color: var(--text-faint);
    }
    .metric-pill-value {
      font-size: 18px;
      font-weight: 800;
      line-height: 1.1;
      color: var(--navy);
    }
    .metric-pill-sub {
      font-size: 12px;
      color: var(--text-muted);
    }
    .alert {
      padding: 10px 14px; border-radius: var(--radius); margin-bottom: 16px;
      font-size: 13px; font-weight: 600; border: 1px solid transparent;
    }
    .alert-success { background: var(--green-light); color: var(--green); border-color: #86efac; }
    .alert-error { background: var(--red-light); color: var(--red); border-color: #fca5a5; }

    /* ── Date picker strip ── */
    .date-strip {
      display: flex; align-items: center; gap: 10px;
      background: var(--surface); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 8px 14px;
      box-shadow: var(--shadow-sm);
    }
    .date-strip label { font-size: 12px; font-weight: 600; color: var(--text-muted); white-space: nowrap; }
    .date-strip input[type="date"] {
      border: 1px solid var(--border); border-radius: 6px; padding: 5px 10px;
      font-size: 13px; font-family: var(--font); color: var(--text); background: var(--surface-2);
      cursor: pointer; outline: none;
    }
    .date-strip input[type="date"]:focus { border-color: var(--teal); box-shadow: 0 0 0 3px rgba(13,122,107,.12); }
    .date-strip .btn-today {
      background: var(--teal); color: #fff; border: none; border-radius: 6px;
      padding: 5px 12px; font-size: 12px; font-weight: 600; cursor: pointer;
      transition: background .15s; white-space: nowrap;
    }
    .date-strip .btn-today:hover { background: var(--teal-hover); }
    .date-strip .is-today { font-size: 12px; color: var(--teal); font-weight: 600; }

    /* ── City tabs ── */
    .city-tabs { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 20px; border-bottom: 2px solid var(--border); padding-bottom: 0; }
    .city-tab {
      padding: 9px 18px; font-size: 13px; font-weight: 600; text-decoration: none;
      color: var(--text-muted); border-radius: 8px 8px 0 0; border: 1px solid transparent;
      border-bottom: none; margin-bottom: -2px; transition: all .15s; background: transparent;
    }
    .city-tab:hover { color: var(--navy); background: var(--surface); border-color: var(--border); }
    .city-tab.active {
      color: var(--navy); background: var(--surface);
      border-color: var(--border); border-bottom-color: var(--surface);
    }
    .city-tab .count {
      display: inline-flex; align-items: center; justify-content: center;
      background: var(--teal); color: #fff;
      min-width: 18px; height: 18px; padding: 0 5px;
      border-radius: 9px; font-size: 11px; font-weight: 700; margin-left: 6px;
    }
    .city-tab.active .count { background: var(--navy); }

    /* ── Vacancy grid ── */
    .vacancies-grid { display: flex; flex-direction: column; gap: 20px; }

    /* ── Vacancy card ── */
    .vacancy-card {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); overflow: hidden;
    }
    .vacancy-header {
      padding: 14px 18px; display: flex; align-items: center;
      gap: 12px; border-bottom: 1px solid var(--border-soft);
      background: var(--surface-2);
    }
    .vacancy-icon {
      width: 36px; height: 36px; border-radius: 8px;
      display: flex; align-items: center; justify-content: center;
      font-size: 18px; flex-shrink: 0;
    }
    .vacancy-icon.scheduling { background: var(--teal-light); }
    .vacancy-icon.cv-only    { background: var(--amber-light); }
    .vacancy-icon.closed     { background: var(--red-light); }
    .vacancy-meta { flex: 1; min-width: 0; }
    .vacancy-title { font-size: 15px; font-weight: 700; color: var(--navy); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .vacancy-role  { font-size: 12px; color: var(--text-muted); margin-top: 1px; }
    .vacancy-badges { display: flex; gap: 6px; flex-wrap: wrap; align-items: center; }

    /* ── Status badges ── */
    .badge {
      display: inline-flex; align-items: center; gap: 4px;
      padding: 3px 9px; border-radius: 20px; font-size: 11px; font-weight: 700;
      white-space: nowrap; letter-spacing: .02em;
    }
    .badge-scheduling { background: var(--teal-light);   color: var(--teal); }
    .badge-cv-only    { background: var(--amber-light);  color: var(--amber); }
    .badge-closed     { background: var(--red-light);    color: var(--red); }
    .badge-nuevo      { background: #f3f4f6;              color: #6b7280; }
    .badge-registrado { background: var(--green-light);  color: var(--green); }
    .badge-validando  { background: var(--blue-light);   color: var(--blue); }
    .badge-aprobado   { background: #ccfbf1;             color: #0f766e; }
    .badge-contactado { background: var(--purple-light); color: var(--purple); }
    .badge-contratado { background: #dbeafe;             color: #1d4ed8; }
    .badge-rechazado  { background: var(--red-light);    color: var(--red); }
    .badge-human-review { background: #fef3c7; color: #92400e; }
    .badge-female { background: #fce7f3; color: #be185d; border: 1px solid #f9a8d4; }
    .badge-unread { background: #dbeafe; color: #1d4ed8; }

    .dot { width: 7px; height: 7px; border-radius: 50%; display: inline-block; }
    .dot-green  { background: var(--green); }
    .dot-amber  { background: var(--amber); }
    .dot-red    { background: var(--red); }
    .dot-gray   { background: var(--text-faint); }

    /* ── Sections inside card ── */
    .vacancy-body { padding: 0; }
    .section {
      border-top: 1px solid var(--border-soft);
      padding: 14px 18px;
    }
    .section:first-child { border-top: none; }
    .section-header {
      display: flex; align-items: center; justify-content: space-between;
      margin-bottom: 10px; gap: 8px;
    }
    .section-title {
      font-size: 12px; font-weight: 700; text-transform: uppercase;
      letter-spacing: .06em; color: var(--text-muted);
      display: flex; align-items: center; gap: 6px;
    }
    .section-count {
      font-size: 11px; font-weight: 700; color: var(--text-faint);
      background: var(--gray-light); padding: 2px 8px; border-radius: 10px;
    }

    /* ── Bookings table ── */
    .bookings-table { width: 100%; border-collapse: collapse; }
    .bookings-table th {
      font-size: 11px; font-weight: 700; text-transform: uppercase;
      letter-spacing: .05em; color: var(--text-faint);
      padding: 6px 10px; border-bottom: 1px solid var(--border-soft);
      text-align: left; background: var(--surface-2);
    }
    .bookings-table td {
      padding: 9px 10px; border-bottom: 1px solid var(--border-soft);
      font-size: 13px; vertical-align: middle;
    }
    .bookings-table tr:last-child td { border-bottom: none; }
    .bookings-table tr:hover td { background: #fafbfc; }
    .time-pill {
      display: inline-flex; align-items: center; justify-content: center;
      background: var(--navy); color: #fff; font-size: 12px; font-weight: 700;
      padding: 3px 10px; border-radius: 6px; min-width: 64px; letter-spacing: .02em;
    }
    .booking-status-confirmed  { color: var(--green);  font-weight: 600; }
    .booking-status-scheduled  { color: var(--blue);   font-weight: 600; }
    .booking-status-rescheduled{ color: var(--amber);  font-weight: 600; }
    .booking-status-no_show    { color: var(--red);    font-weight: 600; }
    .booking-status-cancelled  { color: var(--text-faint); font-weight: 500; text-decoration: line-through; }

    /* ── Candidates list ── */
    .candidates-list { display: flex; flex-direction: column; gap: 1px; }
    .candidate-row {
      display: grid;
      grid-template-columns: 1fr 120px 90px 90px auto;
      gap: 8px; align-items: center;
      padding: 8px 10px; border-radius: 6px;
      transition: background .12s;
    }
    .candidate-row:hover { background: var(--surface-2); }
    .candidate-row-female {
      background: linear-gradient(90deg, #fff1f7 0%, #ffffff 55%);
      border: 1px solid #fbcfe8;
    }
    .candidate-row-female:hover { background: #fde7f3; }
    .candidate-name { font-weight: 600; color: var(--navy); font-size: 13px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .candidate-doc  { font-size: 12px; color: var(--text-muted); }
    .candidate-extra { font-size: 11px; color: var(--text-muted); margin-top: 3px; line-height: 1.45; }
    .candidate-note {
      font-size: 11px;
      color: var(--navy);
      margin-top: 5px;
      line-height: 1.45;
      padding: 5px 8px;
      background: #f8fafc;
      border-left: 3px solid #cbd5e1;
      border-radius: 6px;
      max-width: 560px;
    }
    .candidate-dev-meta { font-size: 11px; color: var(--blue); margin-top: 4px; font-weight: 600; }
    .candidate-flags { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 4px; }
    .candidate-phone a { color: var(--teal); font-weight: 600; font-size: 12px; text-decoration: none; }
    .candidate-phone a:hover { text-decoration: underline; }
    .cv-pill {
      display: inline-flex; align-items: center; gap: 3px;
      font-size: 11px; font-weight: 700; padding: 2px 8px; border-radius: 10px;
    }
    .cv-yes  { background: var(--green-light);  color: var(--green); }
    .cv-no   { background: var(--gray-light);   color: var(--text-faint); }
    .link-detail { font-size: 12px; color: var(--teal); font-weight: 600; text-decoration: none; white-space: nowrap; }
    .link-detail:hover { text-decoration: underline; }
    .action-stack { display: flex; gap: 4px; flex-wrap: wrap; align-items: center; }
    .action-form { display: inline; }
    .action-btn {
      border: 1px solid var(--border); border-radius: 999px; padding: 4px 8px;
      background: var(--surface); font-size: 11px; font-weight: 700; cursor: pointer;
      transition: all .15s; color: var(--text-muted);
    }
    .action-btn:hover { color: var(--navy); background: var(--gray-light); }
    .action-btn:disabled { opacity: .55; cursor: default; }
    .action-btn-ok { border-color: #86efac; background: var(--green-light); color: var(--green); }
    .action-btn-warn { border-color: #fcd34d; background: var(--amber-light); color: var(--amber); }
    .action-btn-danger { border-color: #fca5a5; background: var(--red-light); color: var(--red); }
    .action-btn-neutral { border-color: #cbd5e1; background: #eef2f7; color: #475569; }

    /* ── CV-Only notice ── */
    .cv-only-notice {
      display: flex; align-items: flex-start; gap: 10px;
      background: var(--amber-light); border: 1px solid #fcd34d;
      border-radius: 8px; padding: 10px 14px; margin-bottom: 12px;
    }
    .cv-only-notice .icon { font-size: 18px; flex-shrink: 0; margin-top: 1px; }
    .cv-only-notice p { font-size: 12px; color: var(--amber); font-weight: 600; line-height: 1.4; }
    .cv-only-notice span { font-weight: 400; color: #92400e; }

    /* ── Empty state ── */
    .empty-state {
      text-align: center; padding: 24px 16px;
      color: var(--text-faint); font-size: 13px;
    }
    .empty-state .empty-icon { font-size: 28px; margin-bottom: 6px; }

    /* ── Legacy section ── */
    .legacy-section {
      margin-top: 32px;
      background: var(--surface); border: 1px solid var(--border);
      border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-sm);
    }
    .legacy-header {
      padding: 12px 18px; background: var(--surface-2);
      border-bottom: 1px solid var(--border-soft);
      display: flex; align-items: center; justify-content: space-between;
    }
    .legacy-header h3 { font-size: 14px; font-weight: 700; color: var(--navy); }
    .legacy-table { width: 100%; border-collapse: collapse; }
    .legacy-table th { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: var(--text-faint); padding: 8px 12px; background: var(--surface-2); border-bottom: 1px solid var(--border); text-align: left; }
    .legacy-table td { padding: 9px 12px; border-bottom: 1px solid var(--border-soft); font-size: 13px; }
    .legacy-table tr:last-child td { border-bottom: none; }
    .legacy-table tr:hover td { background: var(--surface-2); }
    .legacy-table tr.legacy-row-female td { background: #fff5fa; }
    .legacy-table tr.legacy-row-female:hover td { background: #fde7f3; }
    .bookings-table tr.row-female td { background: #fff7fb; }

    /* ── Export bar ── */
    .export-bar {
      display: flex; gap: 8px; flex-wrap: wrap;
      padding: 12px 18px; background: var(--surface-2);
      border-top: 1px solid var(--border-soft);
    }
    .export-btn {
      font-size: 12px; font-weight: 600; color: var(--text-muted);
      border: 1px solid var(--border); border-radius: 6px; padding: 5px 12px;
      background: var(--surface); text-decoration: none; transition: all .15s;
    }
    .export-btn:hover { background: var(--gray-light); color: var(--navy); }
    .filter-strip {
      display: flex; gap: 10px; flex-wrap: wrap; align-items: flex-end;
      background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius);
      padding: 10px 14px; box-shadow: var(--shadow-sm);
    }
    .filter-field { display: flex; flex-direction: column; gap: 4px; min-width: 150px; }
    .filter-field label { font-size: 11px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: .04em; }
    .filter-field input,
    .filter-field select {
      border: 1px solid var(--border); border-radius: 6px; padding: 7px 10px;
      font-size: 13px; color: var(--text); background: var(--surface-2);
    }
    .vacancy-filter-bar { margin: 0 18px 14px; }
    .filter-note { font-size: 12px; color: var(--text-muted); }

    /* ── Responsive ── */
    @media (max-width: 960px) {
      .navbar {
        flex-wrap: wrap;
        height: auto;
        padding: 10px 16px;
        gap: 10px 16px;
      }
      .navbar .spacer { display: none; }
      .navbar form { width: 100%; }
      .navbar .btn-logout {
        width: 100%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }
      .page { padding: 18px 14px 42px; }
      .header-metrics { width: 100%; }
      .metric-pill {
        flex: 1 1 220px;
        min-width: 0;
      }
      .date-strip {
        width: 100%;
        flex-wrap: wrap;
      }
      .city-tabs {
        flex-wrap: nowrap;
        overflow-x: auto;
        padding-bottom: 6px;
        scrollbar-width: thin;
      }
      .city-tab { flex: 0 0 auto; }
      .vacancy-header,
      .section-header,
      .legacy-header {
        align-items: flex-start;
      }
      .candidate-row {
        grid-template-columns: minmax(0, 1fr) 110px 90px auto;
      }
      .candidate-phone { grid-column: 1 / -1; }
      .candidate-note { max-width: none; }
      .filter-field {
        flex: 1 1 180px;
        min-width: 0;
      }
    }
    @media (max-width: 768px) {
      .page { padding: 16px 12px 40px; }
      .page-header {
        flex-direction: column;
        align-items: stretch;
      }
      .header-metrics { width: 100%; }
      .metric-pill { width: 100%; }
      .date-strip { align-items: stretch; }
      .date-strip input[type="date"],
      .date-strip .btn-today {
        width: 100%;
      }
      .vacancy-header {
        flex-direction: column;
        align-items: flex-start;
        padding: 14px;
      }
      .vacancy-meta,
      .vacancy-badges,
      .section-count {
        width: 100%;
      }
      .section,
      .legacy-header {
        padding: 14px;
      }
      .vacancy-filter-bar { margin: 0 14px 14px; }
      .filter-strip {
        flex-direction: column;
        align-items: stretch;
      }
      .filter-field { width: 100%; }
      .bookings-table,
      .legacy-table {
        display: block;
        overflow-x: auto;
        white-space: nowrap;
      }
      .candidate-row {
        grid-template-columns: 1fr;
        gap: 6px;
        align-items: flex-start;
        padding: 12px;
        border: 1px solid var(--border-soft);
        background: var(--surface);
      }
      .candidate-row .candidate-doc,
      .candidate-row .candidate-phone { display: block; }
      .candidate-phone a { font-size: 13px; }
      .action-stack { width: 100%; }
      .export-bar { flex-direction: column; }
      .export-btn {
        width: 100%;
        text-align: center;
      }
    }
  </style>
</head>
<body>

<nav class="navbar">
  <a class="brand" href="/admin" aria-label="LoginPro">
    <img src="/public/logo-loginpro.svg" alt="LoginPro" />
  </a>
  <a href="/admin">Panel</a>
  <a href="/admin/vacancies">Vacantes</a>
  <% if (canManageUsers) { %><a href="/admin/users">Usuarios</a><% } %>
  <% if (role === 'dev') { %>
    <a href="/admin/monitor">Monitor</a>
  <% } %>
  <span class="spacer"></span>
  <form method="post" action="/logout">
    <button type="submit" class="btn-logout">Cerrar sesión</button>
  </form>
</nav>

<%
  const isLegacyMode = typeof mode === 'undefined' || mode === 'legacy';
  const vacancyFilterFields = ['transportMode', 'neighborhood', 'locality'];
  const vacancyFilterLabels = {
    transportMode: 'Medio de transporte',
    neighborhood: 'Barrio',
    locality: 'Localidad / zona'
  };
  function normalizeCityName(value) {
    return String(value || '')
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, '')
      .toLowerCase();
  }
  function vacancyUsesLocality(vacancyOrCity) {
    const city = typeof vacancyOrCity === 'string'
      ? vacancyOrCity
      : (vacancyOrCity && vacancyOrCity.city) || '';
    return normalizeCityName(city) === 'bogota';
  }
  function getResidenceLabel(vacancyOrCity) {
    return vacancyUsesLocality(vacancyOrCity) ? 'Localidad' : 'Barrio';
  }
  function getCandidateResidenceValue(candidate, vacancyOrCity = null) {
    if (!candidate) return '';
    if (vacancyUsesLocality(vacancyOrCity || candidate.vacancy || candidate.city)) {
      return candidate.locality || candidate.neighborhood || candidate.zone || '';
    }
    return candidate.neighborhood || candidate.locality || candidate.zone || '';
  }
  function getVacancyFilterFields(vacancyOrCity) {
    return vacancyUsesLocality(vacancyOrCity)
      ? ['transportMode', 'locality']
      : ['transportMode', 'neighborhood', 'locality'];
  }
  function getVacancyFilterLabel(field, vacancyOrCity) {
    if (field === 'locality' && vacancyUsesLocality(vacancyOrCity)) return 'Localidad';
    return vacancyFilterLabels[field] || field;
  }
  const legacyParams = new URLSearchParams();
  if (activeStatusScope) legacyParams.set('status', activeStatusScope);
  if (candidateSearch?.field) legacyParams.set('searchField', candidateSearch.field);
  if (candidateSearch?.text) legacyParams.set('searchText', candidateSearch.text);
  ['neighborhood', 'locality', 'transportMode'].forEach((key) => {
    if (adminFilters && adminFilters[key]) legacyParams.set(key, adminFilters[key]);
  });
  const currentLegacyPath = '/admin' + (legacyParams.toString() ? '?' + legacyParams.toString() : '');
  function appendVacancyFilters(params, excludedVacancyId = null) {
    if (!vacancyFiltersById) return;
    for (const [vacancyId, filters] of Object.entries(vacancyFiltersById)) {
      if (!filters || vacancyId === excludedVacancyId) continue;
      for (const field of vacancyFilterFields) {
        if (filters[field]) params.set('vf_' + vacancyId + '_' + field, filters[field]);
      }
    }
  }
  function appendVacancySearches(params, excludedVacancyId = null) {
    if (!vacancySearchById) return;
    for (const [vacancyId, search] of Object.entries(vacancySearchById)) {
      if (!search || vacancyId === excludedVacancyId) continue;
      if (search.field) params.set('vs_' + vacancyId + '_field', search.field);
      if (search.text) params.set('vs_' + vacancyId + '_text', search.text);
    }
  }
  const dashboardParams = new URLSearchParams();
  if (activeCity) dashboardParams.set('city', activeCity);
  if (selectedDate) dashboardParams.set('date', selectedDate);
  appendVacancyFilters(dashboardParams);
  appendVacancySearches(dashboardParams);
  const currentDashboardPath = '/admin' + (dashboardParams.toString() ? '?' + dashboardParams.toString() : '');
  const currentAdminReturnPath = isLegacyMode ? currentLegacyPath : currentDashboardPath;

  function candidateWhatsappHref(candidate) {
    return '/admin/candidates/' + candidate.id + '/open-whatsapp?returnTo=' + encodeURIComponent(currentAdminReturnPath);
  }

  function candidateDetailHref(candidate) {
    return '/admin/candidates/' + candidate.id + '?returnTo=' + encodeURIComponent(currentAdminReturnPath);
  }

  function candidateLastMessageLabel(candidate) {
    const timestamp = candidate.lastMessageAt || candidate.lastInboundAt || candidate.lastOutboundAt || candidate.createdAt;
    if (!timestamp) return 'Sin mensajes';
    const direction = candidate.lastMessageDirection === 'OUTBOUND' ? 'saliente' : 'entrante';
    return 'Último mensaje ' + direction + ': ' + formatDateTimeCO(timestamp);
  }

  function candidateLastActivityAt(candidate) {
    return candidate.lastMessageAt || candidate.lastInboundAt || candidate.lastOutboundAt || candidate.createdAt || null;
  }

  function candidateRegistrationAt(candidate) {
    return candidate?.createdAt || null;
  }

  function isFemaleCandidate(candidate) {
    return candidate?.gender === 'FEMALE' || candidate?.isFemaleCandidate;
  }

  function formatCandidatePhone(phone) {
    const digits = String(phone || '').replace(/\D+/g, '');
    if (digits.startsWith('57') && digits.length > 10) return digits.slice(2);
    return digits || String(phone || '');
  }

  function candidateFilterValue(candidate, field, vacancyOrCity = null) {
    if (!candidate) return '';
    if (field === 'neighborhood') return candidate.neighborhood || (!vacancyUsesLocality(vacancyOrCity || candidate.vacancy || candidate.city) ? (candidate.locality || candidate.zone || '') : '');
    if (field === 'locality') return vacancyUsesLocality(vacancyOrCity || candidate.vacancy || candidate.city)
      ? (candidate.locality || candidate.neighborhood || candidate.zone || '')
      : (candidate.locality || candidate.zone || '');
    return candidate[field] || '';
  }

  function candidateMatchesVacancyFilters(candidate, filters, vacancyOrCity = null) {
    if (!filters) return true;
    return vacancyFilterFields.every((field) => {
      if (!filters[field]) return true;
      return String(candidateFilterValue(candidate, field, vacancyOrCity)).toLowerCase() === String(filters[field]).toLowerCase();
    });
  }

  function buildVacancyFilterOptions(candidates, field, vacancyOrCity = null) {
    const uniqueValues = new Map();
    for (const candidate of candidates || []) {
      const value = String(candidateFilterValue(candidate, field, vacancyOrCity) || '').trim();
      if (!value) continue;
      const key = value.toLowerCase();
      if (!uniqueValues.has(key)) uniqueValues.set(key, value);
    }
    return Array.from(uniqueValues.values()).sort((a, b) => a.localeCompare(b, 'es', { sensitivity: 'base' }));
  }
  function candidateMatchesVacancySearch(candidate, search) {
    if (!search || !search.text) return true;
    const candidateField = search.field === 'phone'
      ? formatCandidatePhone(candidate && candidate.phone)
      : String((candidate && candidate.documentNumber) || '').replace(/\D+/g, '');
    const queryValue = search.field === 'phone'
      ? String(search.text || '').replace(/\D+/g, '').replace(/^57(?=\d{10,}$)/, '')
      : String(search.text || '').replace(/\D+/g, '');
    if (!queryValue) return true;
    return String(candidateField || '').includes(queryValue);
  }
  function candidateObservationSnippet(candidate) {
    const note = String(candidate?.interviewNotes || '').trim();
    if (!note) return '';
    return note.length > 180 ? note.slice(0, 177) + '…' : note;
  }
%>

<% if (typeof mode === 'undefined' || mode === 'legacy') { %>
