  <table id="legacy-candidates-table" class="legacy-table" style="background:var(--surface);box-shadow:var(--shadow-sm);border-radius:0 0 8px 8px;border:1px solid var(--border);overflow:hidden;">
    <thead>
      <tr>
        <th>Actividad reciente</th><th>Nombre</th><th>Teléfono</th><th>Documento</th>
        <th>Edad</th><th>Barrio / localidad</th><th>Restr. médicas</th><th>Transporte</th><th>Estado</th><th>Rechazo</th><th></th>
      </tr>
    </thead>
    <tbody>
      <% for (const c of candidates) { %>
        <% const uiStatus = normalizeCandidateStatusForUI(c.status); %>
        <% const statusBadge = { NUEVO:'badge-nuevo', REGISTRADO:'badge-registrado', APROBADO:'badge-aprobado', RECHAZADO:'badge-rechazado', CONTACTADO:'badge-contactado', CONTRATADO:'badge-contratado' }; %>
        <% const statusLabel = { NUEVO:'Nuevo', REGISTRADO:'Registrado', APROBADO:'Aprobado', RECHAZADO:'Rechazado', CONTACTADO:'Contactado', CONTRATADO:'Contratado' }; %>
        <tr class="<%= isFemaleCandidate(c) ? 'legacy-row-female' : '' %>">
          <td><%= formatDateTimeCO(role === 'dev' ? candidateLastActivityAt(c) : candidateRegistrationAt(c)) %></td>
