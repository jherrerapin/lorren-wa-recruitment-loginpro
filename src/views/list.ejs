            <%= c.fullName || '—' %>
            <% if (isFemaleCandidate(c)) { %>
              <div class="candidate-flags">
                <span class="badge badge-female"><%= (c.isFemaleHumanReview || isFemaleHumanReviewCandidate(c)) ? 'Candidata femenina' : 'Mujer' %></span>
