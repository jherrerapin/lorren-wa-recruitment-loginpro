  </div>
  <% if (role === 'dev') { %>
    <div style="margin:0 0 14px 0;padding:10px 12px;border:1px solid var(--border);border-radius:8px;background:var(--surface);font-size:13px;">
      <strong>Tokens totales del día</strong> (<%= selectedDate %>)<br>
      Entrada: <strong><%= Number(dailyTokenTotals?.input || 0) %></strong> &middot;
      Salida: <strong><%= Number(dailyTokenTotals?.output || 0) %></strong>
    </div>
  <% } %>

  <% if (successMsg) { %>
    <div class="alert alert-success"><%= successMsg %></div>
  <% } %>
  <% if (errorMsg) { %>
    <div class="alert alert-error"><%= errorMsg %></div>
  <% } %>
  <% if (role === 'dev' && manualReviewCandidates && manualReviewCandidates.length > 0) { %>
    <div class="alert alert-error" style="display:flex;justify-content:space-between;gap:16px;align-items:flex-start;flex-wrap:wrap;">
      <div>
        <strong>Hay <%= manualReviewCandidates.length %> chat<%= manualReviewCandidates.length !== 1 ? 's' : '' %> que requieren intervención manual.</strong>
        <div style="margin-top:4px;font-size:13px;color:#7f1d1d;">La alerta se genera cuando el bot queda pausado por validaciones especiales o dudas que deben responderse de forma humana.</div>
      </div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <% for (const c of manualReviewCandidates.slice(0, 4)) { %>
          <a href="<%= candidateDetailHref(c) %>" class="export-btn" style="border-color:#fecaca;color:#991b1b;background:#fff;"><%= c.fullName || formatCandidatePhone(c.phone) %></a>
        <% } %>
      </div>
    </div>
  <% } %>
  <% if (role === 'dev') { %>
    <div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px;">
      <a href="/admin?status=inbox<%= candidateSearch?.field ? '&searchField=' + encodeURIComponent(candidateSearch.field) : '' %><%= candidateSearch?.text ? '&searchText=' + encodeURIComponent(candidateSearch.text) : '' %>" class="export-btn">Inbox</a>
      <a href="/admin?status=all<%= candidateSearch?.field ? '&searchField=' + encodeURIComponent(candidateSearch.field) : '' %><%= candidateSearch?.text ? '&searchText=' + encodeURIComponent(candidateSearch.text) : '' %>" class="export-btn">Ver todos</a>
    </div>
  <% } %>

  <% if (cities.length > 0) { %>
  <% if (role === 'admin') { %>
  <form method="get" action="/admin" class="filter-strip" style="display:none;">
    <% if (activeCity) { %><input type="hidden" name="city" value="<%= activeCity %>" /><% } %>
    <% if (selectedDate) { %><input type="hidden" name="date" value="<%= selectedDate %>" /><% } %>
    <div class="filter-field">
      <label for="filterTransportMode">Medio de transporte</label>
      <input id="filterTransportMode" type="text" name="transportMode" value="<%= adminFilters?.transportMode || '' %>" placeholder="Moto, bicicleta, bus..." />
    </div>
    <div class="filter-field">
      <label for="filterNeighborhood">Barrio</label>
      <input id="filterNeighborhood" type="text" name="neighborhood" value="<%= adminFilters?.neighborhood || '' %>" placeholder="Ej: Papayo" />
    </div>
    <div class="filter-field">
      <label for="filterLocality">Localidad / zona</label>
      <input id="filterLocality" type="text" name="locality" value="<%= adminFilters?.locality || '' %>" placeholder="Ej: Norte, Sur..." />
    </div>
    <button type="submit" class="export-btn" style="cursor:pointer;">Aplicar filtros</button>
    <a href="/admin<%= activeCity ? '?city=' + encodeURIComponent(activeCity) + (selectedDate ? '&date=' + encodeURIComponent(selectedDate) : '') : (selectedDate ? '?date=' + encodeURIComponent(selectedDate) : '') %>" class="export-btn">Quitar filtros</a>
  </form>
  <% } %>
  <div class="city-tabs" role="tablist">
    <% for (const city of cities) { %>
      <%
        const cityTotal = city.vacancies.reduce((sum, v) => {
          return sum + v.bookingsToday.length + v.registeredNoBooking.length + v.registeredComplete.length + v.completeWithoutCv.length + v.approvedCandidates.length;
        }, 0);
        const cityUrlParams = new URLSearchParams();
        cityUrlParams.set('city', city.name);
        cityUrlParams.set('date', selectedDate);
        appendVacancyFilters(cityUrlParams);
        appendVacancySearches(cityUrlParams);
        const cityUrl = '/admin?' + cityUrlParams.toString();
      %>
      <a href="<%= cityUrl %>" class="city-tab <%= activeCity === city.name ? 'active' : '' %>" role="tab" aria-selected="<%= activeCity === city.name ? 'true' : 'false' %>">
        📍 <%= city.name %>
        <% if (cityTotal > 0) { %><span class="count"><%= cityTotal %></span><% } %>
      </a>
    <% } %>
  </div>
  <% } %>

  <% if (!activeCityData || activeCityData.vacancies.length === 0) { %>
    <div class="empty-state" style="background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-lg);">
      <div class="empty-icon">🏙️</div>
      <p>No hay vacantes activas registradas.</p>
      <p style="margin-top:6px;">
        <a href="/admin/vacancies" style="color:var(--teal);font-weight:600;text-decoration:none;">➕ Crear primera vacante</a>
      </p>
    </div>
  <% } else { %>

  <div class="vacancies-grid">
    <% for (const v of activeCityData.vacancies) { %>
      <%
        const isScheduling = v.schedulingEnabled;
        const isCvOnly     = !v.schedulingEnabled && v.acceptingApplications;
        const isClosed     = !v.acceptingApplications;
        const totalToday   = v.bookingsToday.length;
        const totalPending = v.registeredNoBooking.length + v.registeredComplete.length + v.completeWithoutCv.length;
        let modeIcon  = isClosed ? '🔴' : (isScheduling ? '🗓️' : '📋');
        let modeClass = isClosed ? 'closed' : (isScheduling ? 'scheduling' : 'cv-only');
        let modeBadgeClass = isClosed ? 'badge-closed' : (isScheduling ? 'badge-scheduling' : 'badge-cv-only');
        let modeBadgeText  = isClosed ? 'Cerrada' : (isScheduling ? 'Agendando entrevistas' : 'Solo recepción de HV');
        const currentVacancyFilters = (vacancyFiltersById && vacancyFiltersById[v.id]) || {};
        const currentVacancySearch = (vacancySearchById && vacancySearchById[v.id]) || { field: 'document', text: '' };
        const currentVacancyFilterFields = getVacancyFilterFields(v);
        const vacancyFilterSourceCandidates = [
          ...v.registeredNoBooking,
          ...v.registeredComplete,
          ...v.completeWithoutCv,
          ...v.approvedCandidates,
          ...v.contractedCandidates,
          ...v.bookingsToday.map((booking) => booking.candidate).filter(Boolean)
        ];
        const filteredBookingsToday = v.bookingsToday.filter((booking) => (
          candidateMatchesVacancyFilters(booking.candidate, currentVacancyFilters, v)
          && candidateMatchesVacancySearch(booking.candidate, currentVacancySearch)
        ));
        const filteredRegisteredNoBooking = v.registeredNoBooking.filter((candidate) => (
          candidateMatchesVacancyFilters(candidate, currentVacancyFilters, v)
          && candidateMatchesVacancySearch(candidate, currentVacancySearch)
        ));
        const filteredRegisteredComplete = v.registeredComplete.filter((candidate) => (
          candidateMatchesVacancyFilters(candidate, currentVacancyFilters, v)
          && candidateMatchesVacancySearch(candidate, currentVacancySearch)
        ));
        const filteredCompleteWithoutCv = v.completeWithoutCv.filter((candidate) => (
          candidateMatchesVacancyFilters(candidate, currentVacancyFilters, v)
          && candidateMatchesVacancySearch(candidate, currentVacancySearch)
        ));
        const filteredApprovedCandidates = v.approvedCandidates.filter((candidate) => (
          candidateMatchesVacancyFilters(candidate, currentVacancyFilters, v)
          && candidateMatchesVacancySearch(candidate, currentVacancySearch)
        ));
        const filteredContractedCandidates = v.contractedCandidates.filter((candidate) => (
          candidateMatchesVacancyFilters(candidate, currentVacancyFilters, v)
          && candidateMatchesVacancySearch(candidate, currentVacancySearch)
        ));
        const vacancyFiltersActive = vacancyFilterFields.some((field) => currentVacancyFilters[field]);
        const vacancySearchActive = Boolean(currentVacancySearch.text);
        const clearVacancyFilterParams = new URLSearchParams();
        if (activeCity) clearVacancyFilterParams.set('city', activeCity);
        if (selectedDate) clearVacancyFilterParams.set('date', selectedDate);
        appendVacancyFilters(clearVacancyFilterParams, v.id);
        appendVacancySearches(clearVacancyFilterParams);
        const clearVacancyFilterHref = '/admin' + (clearVacancyFilterParams.toString() ? '?' + clearVacancyFilterParams.toString() : '');
        const clearVacancySearchParams = new URLSearchParams();
        if (activeCity) clearVacancySearchParams.set('city', activeCity);
        if (selectedDate) clearVacancySearchParams.set('date', selectedDate);
        appendVacancyFilters(clearVacancySearchParams);
        appendVacancySearches(clearVacancySearchParams, v.id);
        const clearVacancySearchHref = '/admin' + (clearVacancySearchParams.toString() ? '?' + clearVacancySearchParams.toString() : '');
      %>

      <div class="vacancy-card" id="vacancy-<%= v.id %>">
        <div class="vacancy-header">
          <div class="vacancy-icon <%= modeClass %>" aria-hidden="true"><%= modeIcon %></div>
          <div class="vacancy-meta">
            <div class="vacancy-title"><%= v.title || v.role %></div>
            <div class="vacancy-role"><%= v.role %> &mdash; <%= v.city %></div>
          </div>
          <div class="vacancy-badges">
            <span class="badge <%= modeBadgeClass %>"><span class="dot dot-<%= isClosed ? 'red' : (isScheduling ? 'green' : 'amber') %>"></span><%= modeBadgeText %></span>
            <% if (totalToday > 0) { %><span class="badge" style="background:var(--navy);color:#fff;">📅 <%= totalToday %> hoy</span><% } %>
            <% if (totalPending > 0) { %><span class="badge badge-nuevo"><%= totalPending %> pendiente<%= totalPending > 1 ? 's' : '' %></span><% } %>
          </div>
        </div>

        <form method="get" action="/admin" class="filter-strip vacancy-filter-bar">
          <% if (activeCity) { %><input type="hidden" name="city" value="<%= activeCity %>" /><% } %>
          <% if (selectedDate) { %><input type="hidden" name="date" value="<%= selectedDate %>" /><% } %>
          <% if (vacancyFiltersById) { for (const [vacancyId, filters] of Object.entries(vacancyFiltersById)) { for (const field of vacancyFilterFields) { if (filters && filters[field]) { %>
            <input type="hidden" name="vf_<%= vacancyId %>_<%= field %>" value="<%= filters[field] %>" />
          <% } } } } %>
          <% if (vacancySearchById) { for (const [vacancyId, search] of Object.entries(vacancySearchById)) { if (vacancyId !== v.id) { if (search?.field) { %>
            <input type="hidden" name="vs_<%= vacancyId %>_field" value="<%= search.field %>" />
          <% } if (search?.text) { %>
            <input type="hidden" name="vs_<%= vacancyId %>_text" value="<%= search.text %>" />
          <% } } } } %>
          <div class="filter-field">
            <label for="vacancySearchField_<%= v.id %>">Buscar por</label>
            <select id="vacancySearchField_<%= v.id %>" name="vs_<%= v.id %>_field">
              <option value="document" <%= currentVacancySearch.field === 'document' ? 'selected' : '' %>>Documento</option>
              <option value="phone" <%= currentVacancySearch.field === 'phone' ? 'selected' : '' %>>Celular</option>
            </select>
          </div>
          <div class="filter-field" style="min-width:220px;">
            <label for="vacancySearchText_<%= v.id %>">Número a buscar</label>
            <input id="vacancySearchText_<%= v.id %>" type="text" name="vs_<%= v.id %>_text" value="<%= currentVacancySearch.text || '' %>" placeholder="Documento o celular" />
          </div>
          <button type="submit" class="export-btn" style="cursor:pointer;">Buscar</button>
          <a href="<%= clearVacancySearchHref %>#vacancy-<%= v.id %>" class="export-btn">Quitar búsqueda</a>
          <% if (vacancySearchActive) { %>
            <span class="filter-note">Búsqueda activa en esta vacante.</span>
          <% } %>
        </form>

        <% if (role === 'admin') { %>
        <form method="get" action="/admin" class="filter-strip vacancy-filter-bar">
          <% if (activeCity) { %><input type="hidden" name="city" value="<%= activeCity %>" /><% } %>
          <% if (selectedDate) { %><input type="hidden" name="date" value="<%= selectedDate %>" /><% } %>
          <% if (vacancyFiltersById) { for (const [vacancyId, filters] of Object.entries(vacancyFiltersById)) { if (vacancyId !== v.id) { for (const field of vacancyFilterFields) { if (filters && filters[field]) { %>
            <input type="hidden" name="vf_<%= vacancyId %>_<%= field %>" value="<%= filters[field] %>" />
          <% } } } } } %>
          <% if (vacancySearchById) { for (const [vacancyId, search] of Object.entries(vacancySearchById)) { if (search?.field) { %>
            <input type="hidden" name="vs_<%= vacancyId %>_field" value="<%= search.field %>" />
          <% } if (search?.text) { %>
            <input type="hidden" name="vs_<%= vacancyId %>_text" value="<%= search.text %>" />
          <% } } } %>
          <% for (const field of currentVacancyFilterFields) { %>
            <% const fieldOptions = buildVacancyFilterOptions(vacancyFilterSourceCandidates, field, v); %>
            <% if (fieldOptions.length > 0) { %>
            <div class="filter-field">
              <label for="vacancyFilter_<%= v.id %>_<%= field %>"><%= getVacancyFilterLabel(field, v) %></label>
              <select id="vacancyFilter_<%= v.id %>_<%= field %>" name="vf_<%= v.id %>_<%= field %>">
                <option value="">Todos</option>
                <% for (const option of fieldOptions) { %>
                  <option value="<%= option %>" <%= currentVacancyFilters[field] === option ? 'selected' : '' %>><%= option %></option>
                <% } %>
              </select>
            </div>
            <% } %>
          <% } %>
          <button type="submit" class="export-btn" style="cursor:pointer;">Aplicar filtros</button>
          <a href="<%= clearVacancyFilterHref %>#vacancy-<%= v.id %>" class="export-btn">Quitar filtros</a>
          <% if (vacancyFiltersActive) { %>
            <span class="filter-note">Filtro activo en esta vacante.</span>
          <% } %>
        </form>
        <% } %>

        <div class="vacancy-body">
          <% if (isScheduling) { %>
          <div class="section">
            <div class="section-header">
              <span class="section-title">🗓️&nbsp; Entrevistas — <%= isToday ? 'Hoy' : displayDate %></span>
              <span class="section-count"><%= filteredBookingsToday.length %> cita<%= filteredBookingsToday.length !== 1 ? 's' : '' %></span>
            </div>
            <% if (filteredBookingsToday.length === 0) { %>
              <div class="empty-state"><div class="empty-icon">📭</div><p>Sin entrevistas agendadas para este día.</p></div>
            <% } else { %>
              <table class="bookings-table" role="table">
                <thead><tr><th>Hora</th><th>Candidato</th><th>Documento</th><th><%= getResidenceLabel(v) %></th><th>Estado cita</th><th>HV</th><th>Acciones</th></tr></thead>
                <tbody>
                  <% for (const b of filteredBookingsToday) { %>
                    <% const bs = bookingStatusLabel[b.status] || { cls: '', icon: '•', text: b.status }; %>
                    <tr class="<%= isFemaleCandidate(b.candidate) ? 'row-female' : '' %>">
                      <td><span class="time-pill"><%= b.formattedTime %></span></td>
                      <td>
                        <div style="font-weight:600;color:var(--navy);"><%= b.candidate.fullName || '—' %></div>
                        <% if (isFemaleCandidate(b.candidate)) { %>
                          <div class="candidate-flags">
                            <span class="badge badge-female"><%= b.isFemaleHumanReview ? 'Candidata femenina' : 'Mujer' %></span>
                          </div>
                        <% } %>
                        <% if (b.isFemaleHumanReview) { %>
                          <div class="candidate-flags">
                            <span class="badge badge-human-review">Revisión humana</span>
                          </div>
                        <% } %>
                        <% if (b.candidate.age) { %><div style="font-size:11px;color:var(--text-muted);"><%= b.candidate.age %> años</div><% } %>
                        <% const bookingMeta = candidateOperationalMeta(b.candidate, { includeResidence: false, residenceContext: v }); %>
                        <% if (bookingMeta) { %><div class="candidate-extra"><%= bookingMeta %></div><% } %>
                        <% const bookingNote = candidateObservationSnippet(b.candidate); %>
                        <% if (bookingNote) { %><div class="candidate-note">Observaciones: <%= bookingNote %></div><% } %>
                      </td>
                      <td style="font-size:12px;color:var(--text-muted);"><%= b.candidate.documentType && b.candidate.documentNumber ? b.candidate.documentType + ' ' + b.candidate.documentNumber : '—' %></td>
                      <td style="font-size:12px;color:var(--text-muted);"><%= getCandidateResidenceValue(b.candidate, v) || '—' %></td>
                      <td><span class="<%= bs.cls %>" style="font-size:12px;"><%= bs.icon %> <%= bs.text %></span></td>
                      <td><span class="cv-pill <%= b.candidate.hasCv ? 'cv-yes' : 'cv-no' %>"><%= b.candidate.hasCv ? '✓ HV' : 'Sin HV' %></span></td>
                      <td>
                        <div class="action-stack">
                          <% for (const action of bookingActions) { %>
                            <form method="post" action="/admin/interviews/<%= b.id %>/status" class="action-form">
                              <input type="hidden" name="action" value="<%= action.key %>" />
                              <input type="hidden" name="returnTo" value="<%= currentDashboardPath %>" />
                              <button type="submit" class="action-btn <%= action.cls %>" <%= b.status === action.status ? 'disabled' : '' %>><%= action.label %></button>
                            </form>
                          <% } %>
                          <a href="<%= candidateDetailHref(b.candidate) %>" class="link-detail">Ver →</a>
                        </div>
                      </td>
                    </tr>
                  <% } %>
                </tbody>
              </table>
            <% } %>
          </div>
          <% } %>

          <% if (isScheduling && v.registeredNoBooking.length > 0) { %>
          <div class="section">
            <div class="section-header">
              <span class="section-title">👤&nbsp; Pendientes de agendar</span>
              <span class="section-count"><%= filteredRegisteredNoBooking.length %></span>
            </div>
            <div class="candidates-list">
              <% if (filteredRegisteredNoBooking.length === 0) { %>
                <div class="empty-state"><div class="empty-icon">📭</div><p>No hay candidatos que coincidan con este filtro.</p></div>
              <% } %>
              <% for (const c of filteredRegisteredNoBooking.slice(0, 20)) { %>
                <% const uiSt = normalizeCandidateStatusForUI(c.status); %>
                <% const stBadge = candidateStatusBadge[uiSt] || { cls: 'badge-nuevo', label: uiSt }; %>
                <div class="candidate-row <%= isFemaleCandidate(c) ? 'candidate-row-female' : '' %>">
                  <div>
                    <div class="candidate-name"><%= c.fullName || 'Sin nombre' %></div>
                    <% if (isFemaleCandidate(c)) { %>
                      <div class="candidate-flags">
                        <span class="badge badge-female"><%= c.isFemaleHumanReview ? 'Candidata femenina' : 'Mujer' %></span>
                      </div>
                    <% } %>
                    <% if (c.isFemaleHumanReview) { %>
                      <div class="candidate-flags">
                        <span class="badge badge-human-review">Revisión humana</span>
                      </div>
                    <% } %>
                    <% if (role === 'dev' && c.hasNewInbound) { %>
                      <div class="candidate-flags">
                        <span class="badge badge-unread">Mensaje nuevo</span>
                      </div>
                    <% } %>
                    <div class="candidate-doc"><%= c.documentType && c.documentNumber ? c.documentType + ' ' + c.documentNumber : '—' %></div>
                    <% const candidateMeta = candidateOperationalMeta(c, { residenceContext: v }); %>
                    <% if (candidateMeta) { %><div class="candidate-extra"><%= candidateMeta %></div><% } %>
                    <% const registeredNoBookingNote = candidateObservationSnippet(c); %>
                    <% if (registeredNoBookingNote) { %><div class="candidate-note">Observaciones: <%= registeredNoBookingNote %></div><% } %>
                    <div class="candidate-dev-meta">Fecha de registro: <%= formatDateTimeCO(c.createdAt) %></div>
                    <% if (role === 'dev') { %><div class="candidate-dev-meta"><%= candidateLastMessageLabel(c) %></div><% } %>
                  </div>
                  <div class="candidate-phone"><a href="<%= candidateWhatsappHref(c) %>" <%= role === 'dev' ? '' : 'target="_blank" rel="noopener"' %>>📱 <%= formatCandidatePhone(c.phone) %></a></div>
                  <span class="badge <%= stBadge.cls %>"><%= stBadge.label %></span>
                  <span class="cv-pill <%= c.hasCv ? 'cv-yes' : 'cv-no' %>"><%= c.hasCv ? '✓ HV' : 'Sin HV' %></span>
                  <div class="action-stack">
                    <% if (role === 'dev') { %><a href="<%= candidateWhatsappHref(c) %>" class="action-btn action-btn-neutral">Enviar mensaje</a><% } %>
                    <a href="<%= candidateDetailHref(c) %>" class="link-detail">Ver →</a>
                  </div>
                </div>
              <% } %>
              <% if (filteredRegisteredNoBooking.length > 20) { %><div style="text-align:center;padding:8px;font-size:12px;color:var(--text-muted);">+ <%= filteredRegisteredNoBooking.length - 20 %> más — <a href="/admin?status=registered" style="color:var(--teal);font-weight:600;">ver todos</a></div><% } %>
            </div>
          </div>
          <% } %>

          <% if (isScheduling && v.completeWithoutCv.length > 0) { %>
          <div class="section">
            <div class="section-header">
              <span class="section-title">📄&nbsp; Completos pendientes de HV</span>
              <span class="section-count"><%= filteredCompleteWithoutCv.length %></span>
            </div>
            <div class="candidates-list">
              <% if (filteredCompleteWithoutCv.length === 0) { %>
                <div class="empty-state"><div class="empty-icon">📭</div><p>No hay candidatos que coincidan con este filtro.</p></div>
              <% } %>
              <% for (const c of filteredCompleteWithoutCv.slice(0, 20)) { %>
                <% const uiSt = normalizeCandidateStatusForUI(c.status); %>
                <% const stBadge = candidateStatusBadge[uiSt] || { cls: 'badge-nuevo', label: uiSt }; %>
                <div class="candidate-row <%= isFemaleCandidate(c) ? 'candidate-row-female' : '' %>">
                  <div>
                    <div class="candidate-name"><%= c.fullName || 'Sin nombre' %></div>
                    <% if (isFemaleCandidate(c)) { %>
                      <div class="candidate-flags">
                        <span class="badge badge-female"><%= c.isFemaleHumanReview ? 'Candidata femenina' : 'Mujer' %></span>
                      </div>
                    <% } %>
                    <% if (c.isFemaleHumanReview) { %>
                      <div class="candidate-flags">
                        <span class="badge badge-human-review">Revisión humana</span>
                      </div>
                    <% } %>
                    <% if (role === 'dev' && c.hasNewInbound) { %>
                      <div class="candidate-flags">
                        <span class="badge badge-unread">Mensaje nuevo</span>
                      </div>
                    <% } %>
                    <div class="candidate-doc"><%= c.documentType && c.documentNumber ? c.documentType + ' ' + c.documentNumber : '—' %><% if (c.age) { %>&nbsp;&middot;&nbsp;<%= c.age %> años<% } %></div>
                    <% const candidateMeta = candidateOperationalMeta(c, { residenceContext: v }); %>
                    <% if (candidateMeta) { %><div class="candidate-extra"><%= candidateMeta %></div><% } %>
                    <% const completeWithoutCvNote = candidateObservationSnippet(c); %>
                    <% if (completeWithoutCvNote) { %><div class="candidate-note">Observaciones: <%= completeWithoutCvNote %></div><% } %>
                    <div class="candidate-dev-meta">Fecha de registro: <%= formatDateTimeCO(c.createdAt) %></div>
                    <% if (role === 'dev') { %><div class="candidate-dev-meta"><%= candidateLastMessageLabel(c) %></div><% } %>
                  </div>
                  <div class="candidate-phone"><a href="<%= candidateWhatsappHref(c) %>" <%= role === 'dev' ? '' : 'target="_blank" rel="noopener"' %>>📱 <%= formatCandidatePhone(c.phone) %></a></div>
                  <span class="badge <%= stBadge.cls %>"><%= stBadge.label %></span>
                  <span class="cv-pill cv-no">Sin HV</span>
                  <div class="action-stack">
                    <form method="post" action="/admin/candidates/<%= c.id %>/request-hv" class="action-form">
                      <input type="hidden" name="returnTo" value="<%= currentDashboardPath %>" />
                      <button type="submit" class="action-btn action-btn-warn" <%= c.outboundWindowOpen ? '' : 'disabled title="Ventana de 24h cerrada"' %>>Solicitar HV</button>
                    </form>
                    <% if (role === 'dev') { %><a href="<%= candidateWhatsappHref(c) %>" class="action-btn action-btn-neutral">Enviar mensaje</a><% } %>
                    <a href="<%= candidateDetailHref(c) %>" class="link-detail">Ver →</a>
                  </div>
                </div>
              <% } %>
              <% if (filteredCompleteWithoutCv.length > 20) { %><div style="text-align:center;padding:8px;font-size:12px;color:var(--text-muted);">+ <%= filteredCompleteWithoutCv.length - 20 %> más — <a href="/admin/export?scope=missing_cv_complete&vacancyId=<%= encodeURIComponent(v.id) %>" style="color:var(--teal);font-weight:600;">ver todos</a></div><% } %>
            </div>
          </div>
          <% } %>

          <% if (isCvOnly) { %>
          <div class="section">
            <div class="section-header">
              <span class="section-title">📥&nbsp; Registrados completos</span>
              <span class="section-count"><%= filteredRegisteredComplete.length %></span>
            </div>
            <div class="cv-only-notice"><span class="icon">⚠️</span><p>Modo <strong>solo recepción de hojas de vida</strong>.<span> El agendamiento está deshabilitado para esta vacante.</span></p></div>
            <% if (filteredRegisteredComplete.length === 0) { %>
              <div class="empty-state"><div class="empty-icon">📭</div><p><%= vacancyFiltersActive ? 'No hay candidatos que coincidan con este filtro.' : 'Aún no hay candidatos registrados.' %></p></div>
            <% } else { %>
              <div class="candidates-list">
                <% for (const c of filteredRegisteredComplete.slice(0, 25)) { %>
                  <% const uiSt = normalizeCandidateStatusForUI(c.status); %>
                  <% const stBadge = candidateStatusBadge[uiSt] || { cls: 'badge-nuevo', label: uiSt }; %>
                  <div class="candidate-row <%= isFemaleCandidate(c) ? 'candidate-row-female' : '' %>">
                    <div>
                      <div class="candidate-name"><%= c.fullName || 'Sin nombre' %></div>
                      <% if (isFemaleCandidate(c)) { %>
                        <div class="candidate-flags">
                          <span class="badge badge-female"><%= c.isFemaleHumanReview ? 'Candidata femenina' : 'Mujer' %></span>
                        </div>
                      <% } %>
                      <% if (c.isFemaleHumanReview) { %>
                        <div class="candidate-flags">
                          <span class="badge badge-human-review">Revisión humana</span>
                        </div>
                      <% } %>
                      <% if (role === 'dev' && c.hasNewInbound) { %>
                        <div class="candidate-flags">
                          <span class="badge badge-unread">Mensaje nuevo</span>
                        </div>
                      <% } %>
                      <div class="candidate-doc"><%= c.documentType && c.documentNumber ? c.documentType + ' ' + c.documentNumber : '—' %><% if (c.age) { %>&nbsp;&middot;&nbsp;<%= c.age %> años<% } %></div>
                    <% const candidateMeta = candidateOperationalMeta(c, { residenceContext: v }); %>
                    <% if (candidateMeta) { %><div class="candidate-extra"><%= candidateMeta %></div><% } %>
                    <% const registeredCompleteNote = candidateObservationSnippet(c); %>
                    <% if (registeredCompleteNote) { %><div class="candidate-note">Observaciones: <%= registeredCompleteNote %></div><% } %>
                    <div class="candidate-dev-meta">Fecha de registro: <%= formatDateTimeCO(c.createdAt) %></div>
                    <% if (role === 'dev') { %><div class="candidate-dev-meta"><%= candidateLastMessageLabel(c) %></div><% } %>
                  </div>
                    <div class="candidate-phone"><a href="<%= candidateWhatsappHref(c) %>" <%= role === 'dev' ? '' : 'target="_blank" rel="noopener"' %>>📱 <%= formatCandidatePhone(c.phone) %></a></div>
                    <span class="badge <%= stBadge.cls %>"><%= stBadge.label %></span>
                    <span class="cv-pill <%= c.hasCv ? 'cv-yes' : 'cv-no' %>"><%= c.hasCv ? '✓ HV' : 'Sin HV' %></span>
                    <div class="action-stack">
                      <% if (role === 'dev') { %><a href="<%= candidateWhatsappHref(c) %>" class="action-btn action-btn-neutral">Enviar mensaje</a><% } %>
                      <a href="<%= candidateDetailHref(c) %>" class="link-detail">Ver →</a>
                    </div>
                  </div>
                <% } %>
                <% if (filteredRegisteredComplete.length > 25) { %><div style="text-align:center;padding:8px;font-size:12px;color:var(--text-muted);">+ <%= filteredRegisteredComplete.length - 25 %> más — <a href="/admin?status=registered" style="color:var(--teal);font-weight:600;">ver todos</a></div><% } %>
              </div>
            <% } %>
          </div>
          <% } %>

          <% if (isCvOnly && v.completeWithoutCv.length > 0) { %>
          <div class="section">
            <div class="section-header">
              <span class="section-title">📄&nbsp; Completos pendientes de HV</span>
              <span class="section-count"><%= filteredCompleteWithoutCv.length %></span>
            </div>
            <div class="candidates-list">
              <% if (filteredCompleteWithoutCv.length === 0) { %>
                <div class="empty-state"><div class="empty-icon">📭</div><p>No hay candidatos que coincidan con este filtro.</p></div>
              <% } %>
              <% for (const c of filteredCompleteWithoutCv.slice(0, 25)) { %>
                <% const uiSt = normalizeCandidateStatusForUI(c.status); %>
                <% const stBadge = candidateStatusBadge[uiSt] || { cls: 'badge-nuevo', label: uiSt }; %>
                <div class="candidate-row <%= isFemaleCandidate(c) ? 'candidate-row-female' : '' %>">
                  <div>
                    <div class="candidate-name"><%= c.fullName || 'Sin nombre' %></div>
                    <% if (isFemaleCandidate(c)) { %>
                      <div class="candidate-flags">
                        <span class="badge badge-female"><%= c.isFemaleHumanReview ? 'Candidata femenina' : 'Mujer' %></span>
                      </div>
                    <% } %>
                    <% if (c.isFemaleHumanReview) { %>
                      <div class="candidate-flags">
                        <span class="badge badge-human-review">Revisión humana</span>
                      </div>
                    <% } %>
                    <% if (role === 'dev' && c.hasNewInbound) { %>
                      <div class="candidate-flags">
                        <span class="badge badge-unread">Mensaje nuevo</span>
                      </div>
                    <% } %>
                    <div class="candidate-doc"><%= c.documentType && c.documentNumber ? c.documentType + ' ' + c.documentNumber : '—' %><% if (c.age) { %>&nbsp;&middot;&nbsp;<%= c.age %> años<% } %></div>
                    <% const candidateMeta = candidateOperationalMeta(c, { residenceContext: v }); %>
                    <% if (candidateMeta) { %><div class="candidate-extra"><%= candidateMeta %></div><% } %>
                    <% const cvOnlyNote = candidateObservationSnippet(c); %>
                    <% if (cvOnlyNote) { %><div class="candidate-note">Observaciones: <%= cvOnlyNote %></div><% } %>
                    <div class="candidate-dev-meta">Fecha de registro: <%= formatDateTimeCO(c.createdAt) %></div>
                    <% if (role === 'dev') { %><div class="candidate-dev-meta"><%= candidateLastMessageLabel(c) %></div><% } %>
                  </div>
                  <div class="candidate-phone"><a href="<%= candidateWhatsappHref(c) %>" <%= role === 'dev' ? '' : 'target="_blank" rel="noopener"' %>>📱 <%= formatCandidatePhone(c.phone) %></a></div>
                  <span class="badge <%= stBadge.cls %>"><%= stBadge.label %></span>
                  <span class="cv-pill cv-no">Sin HV</span>
                  <div class="action-stack">
                    <form method="post" action="/admin/candidates/<%= c.id %>/request-hv" class="action-form">
                      <input type="hidden" name="returnTo" value="<%= currentDashboardPath %>" />
                      <button type="submit" class="action-btn action-btn-warn" <%= c.outboundWindowOpen ? '' : 'disabled title="Ventana de 24h cerrada"' %>>Solicitar HV</button>
                    </form>
                    <% if (role === 'dev') { %><a href="<%= candidateWhatsappHref(c) %>" class="action-btn action-btn-neutral">Enviar mensaje</a><% } %>
                    <a href="<%= candidateDetailHref(c) %>" class="link-detail">Ver →</a>
                  </div>
                </div>
              <% } %>
              <% if (filteredCompleteWithoutCv.length > 25) { %><div style="text-align:center;padding:8px;font-size:12px;color:var(--text-muted);">+ <%= filteredCompleteWithoutCv.length - 25 %> más — <a href="/admin/export?scope=missing_cv_complete&vacancyId=<%= encodeURIComponent(v.id) %>" style="color:var(--teal);font-weight:600;">ver todos</a></div><% } %>
            </div>
          </div>
          <% } %>
          <% if (v.approvedCandidates.length > 0) { %>
          <div class="section">
            <div class="section-header">
              <span class="section-title">Aprobados</span>
              <span class="section-count"><%= filteredApprovedCandidates.length %></span>
            </div>
            <div class="candidates-list">
              <% if (filteredApprovedCandidates.length === 0) { %>
                <div class="empty-state"><div class="empty-icon">-</div><p>No hay candidatos aprobados que coincidan con este filtro.</p></div>
              <% } %>
              <% for (const c of filteredApprovedCandidates.slice(0, 25)) { %>
                <% const uiSt = normalizeCandidateStatusForUI(c.status); %>
                <% const stBadge = candidateStatusBadge[uiSt] || { cls: 'badge-aprobado', label: uiSt }; %>
                <div class="candidate-row <%= isFemaleCandidate(c) ? 'candidate-row-female' : '' %>">
                  <div>
                    <div class="candidate-name"><%= c.fullName || 'Sin nombre' %></div>
                    <% if (isFemaleCandidate(c)) { %>
                      <div class="candidate-flags">
                        <span class="badge badge-female"><%= c.isFemaleHumanReview ? 'Candidata femenina' : 'Mujer' %></span>
                      </div>
                    <% } %>
                    <% if (c.isFemaleHumanReview) { %>
                      <div class="candidate-flags">
                        <span class="badge badge-human-review">Revisión humana</span>
                      </div>
                    <% } %>
                    <% if (role === 'dev' && c.hasNewInbound) { %>
                      <div class="candidate-flags">
                        <span class="badge badge-unread">Mensaje nuevo</span>
                      </div>
                    <% } %>
                    <div class="candidate-doc"><%= c.documentType && c.documentNumber ? c.documentType + ' ' + c.documentNumber : '-' %><% if (c.age) { %>&nbsp;&middot;&nbsp;<%= c.age %> años<% } %></div>
                    <% const approvedCandidateMeta = candidateOperationalMeta(c, { residenceContext: v }); %>
                    <% if (approvedCandidateMeta) { %><div class="candidate-extra"><%= approvedCandidateMeta %></div><% } %>
                    <% const approvedCandidateNote = candidateObservationSnippet(c); %>
                    <% if (approvedCandidateNote) { %><div class="candidate-note">Observaciones: <%= approvedCandidateNote %></div><% } %>
                    <div class="candidate-dev-meta">Fecha de registro: <%= formatDateTimeCO(c.createdAt) %></div>
                    <% if (role === 'dev') { %><div class="candidate-dev-meta"><%= candidateLastMessageLabel(c) %></div><% } %>
                  </div>
                  <div class="candidate-phone"><a href="<%= candidateWhatsappHref(c) %>" <%= role === 'dev' ? '' : 'target="_blank" rel="noopener"' %>>Tel. <%= formatCandidatePhone(c.phone) %></a></div>
                  <span class="badge <%= stBadge.cls %>"><%= stBadge.label %></span>
                  <span class="cv-pill <%= c.hasCv ? 'cv-yes' : 'cv-no' %>"><%= c.hasCv ? 'OK HV' : 'Sin HV' %></span>
                  <div class="action-stack">
                    <% if (role === 'dev') { %><a href="<%= candidateWhatsappHref(c) %>" class="action-btn action-btn-neutral">Enviar mensaje</a><% } %>
                    <a href="<%= candidateDetailHref(c) %>" class="link-detail">Ver -&gt;</a>
                  </div>
                </div>
              <% } %>
              <% if (filteredApprovedCandidates.length > 25) { %><div style="text-align:center;padding:8px;font-size:12px;color:var(--text-muted);">+ <%= filteredApprovedCandidates.length - 25 %> más aprobados</div><% } %>
            </div>
          </div>
          <% } %>

          <% if (v.contractedCandidates.length > 0) { %>
          <div class="section">
            <div class="section-header">
              <span class="section-title">Contratados</span>
              <span class="section-count"><%= filteredContractedCandidates.length %></span>
            </div>
            <div class="candidates-list">
              <% if (filteredContractedCandidates.length === 0) { %>
                <div class="empty-state"><div class="empty-icon">-</div><p>No hay contratados que coincidan con este filtro.</p></div>
              <% } %>
              <% for (const c of filteredContractedCandidates.slice(0, 25)) { %>
                <% const uiSt = normalizeCandidateStatusForUI(c.status); %>
                <% const stBadge = candidateStatusBadge[uiSt] || { cls: 'badge-contratado', label: uiSt }; %>
                <div class="candidate-row <%= isFemaleCandidate(c) ? 'candidate-row-female' : '' %>">
                  <div>
                    <div class="candidate-name"><%= c.fullName || 'Sin nombre' %></div>
                    <% if (isFemaleCandidate(c)) { %>
                      <div class="candidate-flags">
                        <span class="badge badge-female"><%= c.isFemaleHumanReview ? 'Candidata femenina' : 'Mujer' %></span>
                      </div>
                    <% } %>
                    <% if (role === 'dev' && c.hasNewInbound) { %>
                      <div class="candidate-flags">
                        <span class="badge badge-unread">Mensaje nuevo</span>
                      </div>
                    <% } %>
                    <div class="candidate-doc"><%= c.documentType && c.documentNumber ? c.documentType + ' ' + c.documentNumber : '-' %><% if (c.age) { %>&nbsp;&middot;&nbsp;<%= c.age %> años<% } %></div>
                    <% const contractedCandidateMeta = candidateOperationalMeta(c, { residenceContext: v }); %>
                    <% if (contractedCandidateMeta) { %><div class="candidate-extra"><%= contractedCandidateMeta %></div><% } %>
                    <% const contractedCandidateNote = candidateObservationSnippet(c); %>
                    <% if (contractedCandidateNote) { %><div class="candidate-note">Observaciones: <%= contractedCandidateNote %></div><% } %>
                    <div class="candidate-dev-meta">Fecha de registro: <%= formatDateTimeCO(c.createdAt) %></div>
                    <% if (role === 'dev') { %><div class="candidate-dev-meta"><%= candidateLastMessageLabel(c) %></div><% } %>
                  </div>
                  <div class="candidate-phone"><a href="<%= candidateWhatsappHref(c) %>" <%= role === 'dev' ? '' : 'target="_blank" rel="noopener"' %>>Tel. <%= formatCandidatePhone(c.phone) %></a></div>
                  <span class="badge <%= stBadge.cls %>"><%= stBadge.label %></span>
                  <span class="cv-pill <%= c.hasCv ? 'cv-yes' : 'cv-no' %>"><%= c.hasCv ? 'OK HV' : 'Sin HV' %></span>
                  <div class="action-stack">
                    <% if (role === 'dev') { %><a href="<%= candidateWhatsappHref(c) %>" class="action-btn action-btn-neutral">Enviar mensaje</a><% } %>
                    <a href="<%= candidateDetailHref(c) %>" class="link-detail">Ver -&gt;</a>
                  </div>
                </div>
              <% } %>
              <% if (filteredContractedCandidates.length > 25) { %><div style="text-align:center;padding:8px;font-size:12px;color:var(--text-muted);">+ <%= filteredContractedCandidates.length - 25 %> más contratados</div><% } %>
            </div>
          </div>
          <% } %>

          <% if (isClosed) { %>
          <div class="section">
            <div style="display:flex;align-items:center;gap:10px;background:var(--red-light);border:1px solid #fca5a5;border-radius:8px;padding:12px 14px;">
              <span style="font-size:20px;">🔴</span>
              <div>
                <p style="font-weight:700;color:var(--red);font-size:13px;">Vacante cerrada — no recibe nuevas postulaciones</p>
                <p style="font-size:12px;color:#991b1b;margin-top:2px;">Los datos históricos siguen disponibles en la vista por estado.</p>
              </div>
            </div>
          </div>
          <% } %>
        </div>

        <div class="export-bar">
          <a href="/admin/export?scope=registered&vacancyId=<%= encodeURIComponent(v.id) %>" class="export-btn">↓ Descargar registrados</a>
          <a href="/admin/export?scope=missing_cv_complete&vacancyId=<%= encodeURIComponent(v.id) %>" class="export-btn">↓ Descargar pendientes HV</a>
          <a href="/admin/export?scope=approved&vacancyId=<%= encodeURIComponent(v.id) %>" class="export-btn">↓ Descargar aprobados</a>
          <a href="/admin/export?scope=all&vacancyId=<%= encodeURIComponent(v.id) %>" class="export-btn">↓ Descargar todos</a>
          <a href="/admin/export?scope=contracted&vacancyId=<%= encodeURIComponent(v.id) %>" class="export-btn">Contratados</a>
          <a href="/admin/outreach/approved" class="export-btn">↗ Mensajes a aprobados</a>
          <a href="/admin/vacancies" class="export-btn" style="margin-left:auto;">⚙️ Gestionar vacantes</a>
        </div>
      </div>
    <% } %>
  </div>
  <% } %>

  <% if (role === 'dev' && manualReviewCandidates && manualReviewCandidates.length > 0) { %>
  <div class="legacy-section" style="margin-top:24px;">
    <div class="legacy-header">
      <h3>Atención manual pendiente <span style="font-weight:400;color:var(--text-muted);font-size:13px;">(<%= manualReviewCandidates.length %>)</span></h3>
      <span style="font-size:12px;color:var(--text-muted);">Chats que requieren seguimiento humano</span>
    </div>
    <table class="legacy-table">
      <thead><tr><th>Actividad</th><th>Nombre</th><th>Motivo</th><th>Teléfono</th><th>Estado</th><th></th></tr></thead>
      <tbody>
        <% for (const c of manualReviewCandidates.slice(0, 12)) { %>
          <% const uiSt = normalizeCandidateStatusForUI(c.status); %>
          <% const stBadge = { NUEVO:{cls:'badge-nuevo',label:'Nuevo'}, REGISTRADO:{cls:'badge-registrado',label:'Registrado'}, APROBADO:{cls:'badge-aprobado',label:'Aprobado'}, RECHAZADO:{cls:'badge-rechazado',label:'Rechazado'}, CONTACTADO:{cls:'badge-contactado',label:'Contactado'}, CONTRATADO:{cls:'badge-contratado',label:'Contratado'} }; %>
          <tr class="<%= isFemaleCandidate(c) ? 'legacy-row-female' : '' %>">
            <td style="font-size:12px;color:var(--text-muted);"><%= formatDateTimeCO(candidateLastActivityAt(c)) %></td>
            <td style="font-weight:600;">
              <%= c.fullName || '—' %>
              <% if (role === 'dev') { %>
                <div class="candidate-dev-meta">Fecha de registro: <%= formatDateTimeCO(c.createdAt) %></div>
                <div class="candidate-dev-meta"><%= candidateLastMessageLabel(c) %></div>
              <% } %>
            </td>
            <td style="font-size:12px;color:var(--text-muted);"><%= c.botPauseReason || 'Revisión manual solicitada' %></td>
            <td><a href="<%= candidateWhatsappHref(c) %>" style="color:#25d366;font-weight:600;"><%= formatCandidatePhone(c.phone) %></a></td>
            <td><span class="badge <%= (stBadge[uiSt]||{cls:'badge-nuevo'}).cls %>"><%= (stBadge[uiSt]||{label:uiSt}).label %></span></td>
            <td><a href="<%= candidateDetailHref(c) %>" class="link-detail">Ver chat -></a></td>
          </tr>
        <% } %>
      </tbody>
    </table>
  </div>
  <% } %>

  <% if (role === 'dev' && legacyCandidates && legacyCandidates.length > 0) { %>
  <div class="legacy-section">
    <div class="legacy-header">
      <h3>⚙️ Candidatos sin vacante asignada <span style="font-weight:400;color:var(--text-muted);font-size:13px;">(<%= legacyCandidates.length %>)</span></h3>
      <a href="/admin?status=all" style="font-size:12px;color:var(--teal);font-weight:600;text-decoration:none;">Ver todos →</a>
    </div>
    <table class="legacy-table">
      <thead><tr><th>Nombre</th><th>Teléfono</th><th>Documento</th><th>Estado</th><th>HV</th><th>Registro</th><th></th></tr></thead>
      <tbody>
        <% for (const c of legacyCandidates.slice(0, 10)) { %>
          <% const uiSt = normalizeCandidateStatusForUI(c.status); %>
          <% const stBadge = { NUEVO:{cls:'badge-nuevo',label:'Nuevo'}, REGISTRADO:{cls:'badge-registrado',label:'Registrado'}, APROBADO:{cls:'badge-aprobado',label:'Aprobado'}, RECHAZADO:{cls:'badge-rechazado',label:'Rechazado'}, CONTACTADO:{cls:'badge-contactado',label:'Contactado'}, CONTRATADO:{cls:'badge-contratado',label:'Contratado'} }; %>
          <tr class="<%= isFemaleCandidate(c) ? 'legacy-row-female' : '' %>">
            <td style="font-weight:600;">
              <%= c.fullName || '—' %>
              <% if (isFemaleCandidate(c)) { %>
                <div class="candidate-flags">
                  <span class="badge badge-female"><%= c.isFemaleHumanReview ? 'Candidata femenina' : 'Mujer' %></span>
                </div>
              <% } %>
              <% if (c.isFemaleHumanReview) { %>
                <div class="candidate-flags">
                  <span class="badge badge-human-review">Revisión humana</span>
                </div>
              <% } %>
              <% if (role === 'dev' && c.hasNewInbound) { %>
                <div class="candidate-flags">
                  <span class="badge badge-unread">Mensaje nuevo</span>
                </div>
              <% } %>
              <% if (role === 'dev') { %>
                <div class="candidate-dev-meta">Fecha de registro: <%= formatDateTimeCO(c.createdAt) %></div>
                <div class="candidate-dev-meta"><%= candidateLastMessageLabel(c) %></div>
              <% } %>
              <% const orphanCandidateNote = candidateObservationSnippet(c); %>
              <% if (orphanCandidateNote) { %>
                <div class="candidate-note">Observaciones: <%= orphanCandidateNote %></div>
              <% } %>
            </td>
            <td><a href="<%= candidateWhatsappHref(c) %>" <%= role === 'dev' ? '' : 'target="_blank"' %> style="color:#25d366;font-weight:600;"><%= formatCandidatePhone(c.phone) %></a></td>
            <td style="font-size:12px;color:var(--text-muted);"><%= c.documentType && c.documentNumber ? c.documentType + ' ' + c.documentNumber : '—' %></td>
            <td><span class="badge <%= (stBadge[uiSt]||{cls:'badge-nuevo'}).cls %>"><%= (stBadge[uiSt]||{label:uiSt}).label %></span></td>
            <td><span class="cv-pill <%= c.hasCv ? 'cv-yes' : 'cv-no' %>"><%= c.hasCv ? '✓ HV' : 'Sin HV' %></span></td>
            <td style="font-size:12px;color:var(--text-muted);"><%= formatDateTimeCO(c.createdAt) %></td>
            <td><a href="<%= candidateDetailHref(c) %>" class="link-detail">Ver →</a></td>
          </tr>
        <% } %>
        <% if (legacyCandidates.length > 10) { %>
          <tr><td colspan="7" style="text-align:center;padding:10px;font-size:12px;color:var(--text-muted);">+ <%= legacyCandidates.length - 10 %> más — <a href="/admin?status=all" style="color:var(--teal);font-weight:600;">ver todos</a></td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
  <% } %>

</div>
<% } %>

<script>
  (function () {
    const role = <%- JSON.stringify(role || '') %>;
    if (role === 'dev') return;
    const firstHeader = document.querySelector('#legacy-candidates-table thead th');
    if (firstHeader) firstHeader.textContent = 'Fecha de registro';
  })();
</script>

</body>
</html>


