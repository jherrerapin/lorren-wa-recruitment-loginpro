    ATTENDED:    { cls: 'booking-status-confirmed',   icon: '🙌', text: 'Asistió' },
    RESCHEDULED: { cls: 'booking-status-rescheduled', icon: '🔄', text: 'Reagendado' },
    NO_RESPONSE: { cls: 'booking-status-cancelled',   icon: '📵', text: 'No contesta' },
    NO_SHOW:     { cls: 'booking-status-no_show',     icon: '❌', text: 'No asistió' },
    CANCELLED:   { cls: 'booking-status-cancelled',   icon: '🚫', text: 'Canceló' }
  };
  const bookingActions = [
    { key: 'confirmed', label: 'Confirmada', cls: 'action-btn-ok', status: 'CONFIRMED' },
    { key: 'attended', label: 'Asistió', cls: 'action-btn-ok', status: 'ATTENDED' },
    { key: 'no_response', label: 'No contesta', cls: 'action-btn-neutral', status: 'NO_RESPONSE' },
    { key: 'no_show', label: 'No asistió', cls: 'action-btn-danger', status: 'NO_SHOW' },
    { key: 'cancelled', label: 'Canceló', cls: 'action-btn-neutral', status: 'CANCELLED' },
    { key: 'rescheduled', label: 'Reagendó', cls: 'action-btn-warn', status: 'RESCHEDULED' }
  ];

  const candidateStatusBadge = {
    NUEVO:      { cls: 'badge-nuevo',      label: 'Nuevo' },
    REGISTRADO: { cls: 'badge-registrado', label: 'Registrado' },
    VALIDANDO:  { cls: 'badge-validando',  label: 'Validando' },
    APROBADO:   { cls: 'badge-aprobado',   label: 'Aprobado' },
    CONTACTADO: { cls: 'badge-contactado', label: 'Contactado' },
    CONTRATADO: { cls: 'badge-contratado', label: 'Contratado' },
    RECHAZADO:  { cls: 'badge-rechazado',  label: 'Rechazado' }
  };

  function candidateOperationalMeta(candidate, options = {}) {
    const includeResidence = options.includeResidence !== false;
    const residenceContext = options.residenceContext || candidate?.vacancy || candidate;
    const parts = [];
    const residenceValue = getCandidateResidenceValue(candidate, residenceContext);
    if (includeResidence && residenceValue) parts.push(getResidenceLabel(residenceContext) + ': ' + residenceValue);
    if (candidate.medicalRestrictions) parts.push('Restricciones: ' + candidate.medicalRestrictions);
    if (candidate.transportMode) parts.push('Transporte: ' + candidate.transportMode);
    return parts.join(' · ');
  }
%>

