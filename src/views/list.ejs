        <input type="text" name="locality" value="<%= adminFilters?.locality || '' %>" style="padding:8px 10px;border:1px solid var(--border);border-radius:6px;min-width:170px;" />
      </label>
      <label style="display:flex;flex-direction:column;gap:4px;font-size:12px;color:var(--text-muted);font-weight:600;">Transporte
        <input type="text" name="transportMode" value="<%= adminFilters?.transportMode || '' %>" style="padding:8px 10px;border:1px solid var(--border);border-radius:6px;min-width:160px;" />
      </label>
      <button type="submit" class="export-btn" style="cursor:pointer;">Filtrar</button>
      <a href="/admin?status=<%= activeStatusScope %>" class="export-btn">Limpiar</a>
