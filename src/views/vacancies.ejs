<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Gestión de Vacantes — LoginPro</title>
  <link rel="icon" type="image/png" href="/public/favicon-loginpro.svg" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #f4f5f7; --surface: #ffffff; --surface-2: #f9fafb;
      --border: #e1e4e8; --border-soft: #eaecef;
      --text: #1a1d23; --text-muted: #6b7280; --text-faint: #9ca3af;
      --navy: #1e2d3d; --teal: #0d7a6b; --teal-light: #e6f4f1; --teal-hover: #0a5f53;
      --red: #dc2626; --red-light: #fee2e2;
      --green: #16a34a; --green-light: #dcfce7;
      --amber: #b45309; --amber-light: #fef3c7;
      --gray-light: #f3f4f6;
      --shadow-sm: 0 1px 3px rgba(0,0,0,.08);
      --radius: 8px; --radius-lg: 12px;
      --font: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }
    body { font-family: var(--font); background: var(--bg); color: var(--text); font-size: 14px; line-height: 1.5; }
    .navbar { background: var(--navy); padding: 0 24px; display: flex; align-items: center; gap: 20px; height: 52px; position: sticky; top: 0; z-index: 100; box-shadow: 0 2px 8px rgba(0,0,0,.2); }
    .navbar a { color: #cbd5e0; text-decoration: none; font-size: 13px; font-weight: 500; padding: 4px 2px; border-bottom: 2px solid transparent; transition: color .15s, border-color .15s; }
    .navbar a:hover { color: #fff; border-bottom-color: rgba(255,255,255,.3); }
    .navbar a.nav-active { color: #fff; border-bottom-color: #4fd1c5; }
    .navbar .brand img { height: 28px; display: block; }
    .navbar .spacer { flex: 1; }
    .btn-logout { background: transparent; border: 1px solid rgba(255,255,255,.25); color: #cbd5e0 !important; padding: 5px 12px !important; border-radius: 6px; cursor: pointer; font-size: 12px; font-weight: 500; }
    .btn-logout:hover { border-color: rgba(255,255,255,.6) !important; color: #fff !important; }
    .page { max-width: 1100px; margin: 0 auto; padding: 28px 20px 60px; }
    .page-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; flex-wrap: wrap; gap: 12px; }
    .page-header h1 { font-size: 20px; font-weight: 700; color: var(--navy); }
    .page-header .sub { font-size: 13px; color: var(--text-muted); margin-top: 2px; }
    .alert { padding: 10px 16px; border-radius: var(--radius); font-size: 13px; font-weight: 600; margin-bottom: 20px; }
    .alert-success { background: var(--green-light); color: var(--green); border: 1px solid #86efac; }
    .alert-error   { background: var(--red-light);   color: var(--red);   border: 1px solid #fca5a5; }
    .btn { display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; border-radius: var(--radius); font-size: 13px; font-weight: 600; cursor: pointer; border: none; text-decoration: none; transition: all .15s; }
    .btn-primary   { background: var(--teal);  color: #fff; }
    .btn-primary:hover { background: var(--teal-hover); }
    .btn-secondary { background: var(--surface); color: var(--text-muted); border: 1px solid var(--border); }
    .btn-secondary:hover { background: var(--gray-light); color: var(--navy); }
    .btn-danger    { background: var(--red-light); color: var(--red); border: 1px solid #fca5a5; }
    .btn-danger:hover { background: #fecaca; }
    .btn-sm { padding: 5px 11px; font-size: 12px; }
    .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); overflow: hidden; }
    .city-sections { display: flex; flex-direction: column; gap: 18px; }
    .city-section { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); overflow: hidden; }
    .city-section-header { display: flex; align-items: center; justify-content: space-between; gap: 12px; padding: 14px 16px; background: linear-gradient(135deg, #f8fbfc 0%, #eef6f5 100%); border-bottom: 1px solid var(--border-soft); }
    .city-section-title { font-size: 16px; font-weight: 700; color: var(--navy); }
    .city-section-subtitle { font-size: 12px; color: var(--text-muted); margin-top: 2px; }
    .city-count { display: inline-flex; align-items: center; padding: 5px 10px; border-radius: 999px; background: var(--teal-light); color: var(--teal-hover); font-size: 12px; font-weight: 700; white-space: nowrap; }
    table { width: 100%; border-collapse: collapse; }
    thead th { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: var(--text-faint); padding: 10px 14px; background: var(--surface-2); border-bottom: 1px solid var(--border); text-align: left; white-space: nowrap; }
    tbody td { padding: 12px 14px; border-bottom: 1px solid var(--border-soft); font-size: 13px; vertical-align: middle; }
    tbody tr:last-child td { border-bottom: none; }
    tbody tr:hover td { background: #fafbfc; }
    .badge { display: inline-flex; align-items: center; gap: 4px; padding: 3px 9px; border-radius: 20px; font-size: 11px; font-weight: 700; white-space: nowrap; }
    .badge-open   { background: var(--green-light); color: var(--green); }
    .badge-paused { background: var(--amber-light); color: var(--amber); }
    .badge-closed { background: var(--red-light);   color: var(--red); }
    .dot { width: 7px; height: 7px; border-radius: 50%; display: inline-block; }
    .dot-green { background: var(--green); } .dot-amber { background: var(--amber); } .dot-red { background: var(--red); }
    .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,.45); z-index: 200; align-items: flex-start; justify-content: center; padding: 40px 16px; overflow-y: auto; }
    .modal-overlay.open { display: flex; }
    .modal { background: var(--surface); border-radius: var(--radius-lg); width: 100%; max-width: 680px; box-shadow: 0 20px 60px rgba(0,0,0,.25); }
    .modal-header { padding: 18px 24px 14px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
    .modal-header h2 { font-size: 16px; font-weight: 700; color: var(--navy); }
    .modal-close { background: none; border: none; font-size: 20px; cursor: pointer; color: var(--text-muted); line-height: 1; padding: 4px; border-radius: 4px; }
    .modal-close:hover { color: var(--text); background: var(--gray-light); }
    .modal-body { padding: 20px 24px; }
    .modal-footer { padding: 14px 24px; border-top: 1px solid var(--border); display: flex; justify-content: flex-end; gap: 10px; }
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 14px 20px; }
    .form-grid .full { grid-column: 1 / -1; }
    .form-group { display: flex; flex-direction: column; gap: 5px; }
    .form-group label { font-size: 12px; font-weight: 600; color: var(--text-muted); }
    .form-group input, .form-group select, .form-group textarea {
      border: 1px solid var(--border); border-radius: 6px; padding: 8px 10px;
      font-size: 13px; font-family: var(--font); color: var(--text);
      background: var(--surface-2); outline: none; transition: border-color .15s, box-shadow .15s;
    }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
      border-color: var(--teal); box-shadow: 0 0 0 3px rgba(13,122,107,.12);
    }
    .form-group input[readonly] { background: var(--gray-light); color: var(--text-faint); cursor: default; border-color: var(--border-soft); }
    .form-group textarea { resize: vertical; min-height: 70px; }
    .form-hint { font-size: 11px; color: var(--text-faint); margin-top: 2px; }
    .document-list { display: flex; flex-direction: column; gap: 8px; }
    .document-row { display: flex; gap: 8px; align-items: center; }
    .document-row input { flex: 1; }
    .section-divider { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--text-faint); margin: 16px 0 6px; padding-bottom: 4px; border-bottom: 1px solid var(--border-soft); grid-column: 1 / -1; }
    .op-select-wrap { display: flex; flex-direction: column; gap: 4px; }
    .op-city-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: var(--text-faint); padding: 6px 10px 2px; }
    .toggle-row { display: flex; align-items: center; justify-content: space-between; padding: 12px 14px; border-radius: var(--radius); border: 2px solid var(--border); background: var(--surface-2); transition: border-color .15s, background .15s; }
    .toggle-row.is-active { border-color: var(--teal); background: var(--teal-light); }
    .toggle-row-body { display: flex; flex-direction: column; gap: 2px; }
    .toggle-row-title { font-size: 13px; font-weight: 700; color: var(--text); }
    .toggle-row-desc  { font-size: 11px; color: var(--text-muted); }
    .toggle-switch { position: relative; width: 42px; height: 24px; flex-shrink: 0; }
    .toggle-switch input { opacity: 0; width: 0; height: 0; }
    .toggle-track { position: absolute; inset: 0; cursor: pointer; background: #cbd5e0; border-radius: 24px; transition: background .2s; }
    .toggle-track::before { content: ''; position: absolute; width: 18px; height: 18px; left: 3px; top: 3px; background: #fff; border-radius: 50%; transition: transform .2s; box-shadow: 0 1px 3px rgba(0,0,0,.2); }
    .toggle-switch input:checked + .toggle-track { background: var(--teal); }
    .toggle-switch input:checked + .toggle-track::before { transform: translateX(18px); }
    .mode-group { display: flex; flex-direction: column; gap: 8px; margin-top: 10px; }
    .mode-option { display: flex; align-items: flex-start; gap: 12px; padding: 12px 14px; border-radius: var(--radius); border: 2px solid var(--border); background: var(--surface-2); cursor: pointer; transition: border-color .15s, background .15s, opacity .15s; }
    .mode-option:hover:not(.mode-disabled) { border-color: #a0c4be; background: #f3faf9; }
    .mode-option.mode-disabled { opacity: .45; cursor: not-allowed; pointer-events: none; }
    .mode-option input[type=radio] { margin-top: 2px; width: 16px; height: 16px; accent-color: var(--teal); flex-shrink: 0; cursor: pointer; }
    .mode-option:has(input:checked) { border-color: var(--teal); background: var(--teal-light); }
    .mode-option-title { font-size: 13px; font-weight: 700; color: var(--text); }
    .mode-option-desc  { font-size: 11px; color: var(--text-muted); margin-top: 2px; }
    .schedule-config { display: none; grid-template-columns: 1fr 1fr; gap: 14px 20px; padding: 14px; border: 1px solid var(--border-soft); border-radius: var(--radius); background: var(--surface-2); }
    .schedule-config.is-visible { display: grid; }
    .schedule-days { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 8px; }
    .schedule-day { display: flex; align-items: center; justify-content: center; padding: 8px 10px; border: 1px solid var(--border); border-radius: 999px; background: var(--surface); color: var(--text-muted); font-size: 12px; font-weight: 600; cursor: pointer; transition: border-color .15s, background .15s, color .15s; }
    .schedule-day input { display: none; }
    .schedule-day:has(input:checked) { border-color: var(--teal); background: var(--teal-light); color: var(--teal-hover); }
    .empty-state { text-align: center; padding: 48px 24px; color: var(--text-faint); }
    .empty-state .empty-icon { font-size: 36px; margin-bottom: 10px; }
    .no-ops-warn { font-size: 12px; color: var(--amber); background: var(--amber-light); border: 1px solid #fcd34d; border-radius: var(--radius); padding: 8px 12px; }
    @media (max-width: 640px) {
      .form-grid { grid-template-columns: 1fr; }
      .form-grid .full { grid-column: 1; }
      .schedule-config { grid-template-columns: 1fr; }
      .schedule-days { grid-template-columns: repeat(2, minmax(0, 1fr)); }
      tbody td:nth-child(2), thead th:nth-child(2) { display: none; }
    }
  </style>
</head>
<body>

<nav class="navbar">
  <a class="brand" href="/admin" aria-label="LoginPro">
    <img src="/public/logo-loginpro.svg" alt="LoginPro" />
  </a>
  <a href="/admin">Panel</a>
  <a href="/admin/vacancies" class="nav-active">Vacantes</a>
  <a href="/admin/locations">Ciudades</a>
  <% if (role === 'dev') { %>
    <a href="/admin/monitor">Monitor</a>
  <% } %>
  <span class="spacer"></span>
  <form method="post" action="/logout">
    <button type="submit" class="btn-logout">Cerrar sesión</button>
  </form>
</nav>

<div class="page">
  <div class="page-header">
    <div>
      <h1>Gestión de Vacantes</h1>
      <p class="sub"><%= vacancies.length %> vacante<%= vacancies.length !== 1 ? 's' : '' %> registrada<%= vacancies.length !== 1 ? 's' : '' %></p>
    </div>
    <button class="btn btn-primary" onclick="openCreate()">➕ Nueva vacante</button>
  </div>

  <% if (successMsg) { %><div class="alert alert-success">✅ <%= successMsg %></div><% } %>
  <% if (errorMsg)   { %><div class="alert alert-error">⚠️ <%= errorMsg %></div><% } %>

  <% if (vacancies.length === 0) { %>
    <div class="card">
      <div class="empty-state">
        <div class="empty-icon">[]</div>
        <p>No hay vacantes registradas todavia.</p>
        <p style="margin-top:6px;font-size:13px;">Crea la primera usando el boton de arriba.</p>
      </div>
    </div>
  <% } else { %>
  <%
    const vacancyGroups = vacancies.reduce((groups, vacancy) => {
      const city = vacancy.city || 'Sin ciudad';
      if (!groups[city]) groups[city] = [];
      groups[city].push(vacancy);
      return groups;
    }, {});
    const groupedCities = Object.keys(vacancyGroups).sort((a, b) => a.localeCompare(b, 'es'));
  %>
  <div class="city-sections">
    <% for (const cityName of groupedCities) { %>
      <% const cityVacancies = vacancyGroups[cityName]; %>
      <section class="city-section">
        <div class="city-section-header">
          <div>
            <div class="city-section-title"><%= cityName %></div>
            <div class="city-section-subtitle">Vacantes organizadas para esta ciudad</div>
          </div>
          <div class="city-count"><%= cityVacancies.length %> vacante<%= cityVacancies.length !== 1 ? 's' : '' %></div>
        </div>
        <table>
          <thead><tr>
            <th>Vacante</th>
            <th>Operacion</th>
            <th>Modo bot</th>
            <th>Estado</th>
            <th>Acciones</th>
          </tr></thead>
          <tbody>
            <% for (const v of cityVacancies) { %>
              <%
                const isOpen   = v.isActive && v.acceptingApplications;
                const isPaused = v.isActive && !v.acceptingApplications;
                const isClosed = !v.isActive;
                const badgeCls = isOpen ? 'badge-open' : (isPaused ? 'badge-paused' : 'badge-closed');
                const dotCls   = isOpen ? 'dot-green'  : (isPaused ? 'dot-amber'   : 'dot-red');
                const badgeTxt = isOpen ? 'Abierta'    : (isPaused ? 'Pausada'     : 'Inactiva');
                const modeIcon = v.schedulingEnabled ? 'Agenda' : 'HV';
                const modeTxt  = v.schedulingEnabled ? 'Con entrevista' : 'Solo HV';
                const toggleClass = isOpen ? 'btn-danger' : 'btn-secondary';
                const toggleLabel = isOpen ? 'Pausar'     : (isPaused ? 'Reabrir'  : 'Activar');
                const opLabel = v.operation ? (v.operation.city.name + ' > ' + v.operation.name) : (v.city || '-');
              %>
              <tr>
                <td>
                  <div style="font-weight:700;color:var(--navy);"><%= v.title %></div>
                  <% if (v.role) { %><div style="font-size:11px;color:var(--text-muted);"><%= v.role %></div><% } %>
                </td>
                <td><span style="font-size:12px;"><%= opLabel %></span></td>
                <td><span style="font-size:12px;"><%= modeIcon %> <%= modeTxt %></span></td>
                <td><span class="badge <%= badgeCls %>"><span class="dot <%= dotCls %>"></span><%= badgeTxt %></span></td>
                <td>
                  <div style="display:flex;gap:6px;flex-wrap:wrap;">
                    <button class="btn btn-secondary btn-sm" onclick="openEdit(<%= JSON.stringify(v) %>)">Editar</button>
                    <form method="post" action="/admin/vacancies/<%= v.id %>/toggle" style="display:inline;">
                      <button type="submit" class="btn <%= toggleClass %> btn-sm"><%= toggleLabel %></button>
                    </form>
                    <form method="post" action="/admin/vacancies/<%= v.id %>/delete" style="display:inline;" onsubmit="return confirm('Seguro que deseas eliminar esta vacante?');">
                      <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      </section>
    <% } %>
  </div>
  <% } %>
</div>

<!-- ── Modal Crear ── -->
<div class="modal-overlay" id="modalCreate">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modalCreateTitle">
    <div class="modal-header">
      <h2 id="modalCreateTitle">➕ Nueva vacante</h2>
      <button class="modal-close" onclick="closeModal('modalCreate')" aria-label="Cerrar">&times;</button>
    </div>
    <form method="post" action="/admin/vacancies/create" id="formCreate" onsubmit="injectConfigFields('formCreate','c-isActive','c-flow')">
      <div class="modal-body">
        <div class="form-grid">

          <div class="section-divider">Información básica</div>

          <div class="form-group full">
            <label for="c-operation">Operación / Zona <span style="color:var(--red)">*</span></label>
            <% if (operations.length === 0) { %>
              <div class="no-ops-warn">⚠️ No hay operaciones configuradas. <a href="/admin/locations" style="color:var(--amber);font-weight:700;">Crea ciudades y operaciones primero →</a></div>
              <input type="hidden" name="operationId" value="" />
            <% } else { %>
            <select id="c-operation" name="operationId" required>
              <option value="">— Selecciona operación —</option>
              <% let lastCity = null; %>
              <% for (const op of operations) { %>
                <% if (op.city.name !== lastCity) { lastCity = op.city.name; %>
                  <optgroup label="📍 <%= op.city.name %>">
                <% } %>
                <option value="<%= op.id %>" data-city="<%= op.city.name %>" data-op="<%= op.name %>">
                  <%= op.name %>
                </option>
              <% } %>
            </select>
            <% } %>
            <span class="form-hint">La ciudad se deriva automáticamente de la operación seleccionada.</span>
          </div>

          <div class="form-group">
            <label for="c-title">Título <span style="color:var(--red)">*</span></label>
            <input id="c-title" name="title" type="text" required placeholder="Ej: Auxiliar de Cargue" />
          </div>
          <div class="form-group">
            <label for="c-role">Rol / Cargo</label>
            <input id="c-role" name="role" type="text" placeholder="Ej: Auxiliar de Cargue y Descargue" />
          </div>
          <div class="form-group full">
            <label for="c-address">Zona de operación</label>
            <input id="c-address" name="operationAddress" type="text" placeholder="Ej: Zona industrial / Montevideo / Norte" />
          </div>

          <div class="section-divider">Edad y experiencia</div>
          <div class="form-group">
            <label for="c-minAge">Edad mínima</label>
            <input id="c-minAge" name="minAge" type="number" min="14" max="99" placeholder="18" />
          </div>
          <div class="form-group">
            <label for="c-maxAge">Edad máxima</label>
            <input id="c-maxAge" name="maxAge" type="number" min="14" max="99" placeholder="50" />
          </div>
          <div class="form-group full">
            <label for="c-exp">Experiencia requerida</label>
            <select id="c-exp" name="experienceRequired" onchange="syncExperienceField('c-exp', 'c-exp-time-group')">
              <option value="INDIFFERENT">Indiferente</option>
              <option value="YES">Requerida</option>
              <option value="NO">No requerida</option>
            </select>
          </div>
          <div class="form-group full" id="c-exp-time-group" style="display:none;">
            <label for="c-expTimeText">Tiempo de experiencia requerido</label>
            <input id="c-expTimeText" name="experienceTimeText" type="text" placeholder="Ej: 6 meses, 1 año, experiencia reciente en coordinación" />
            <span class="form-hint">Este texto se guarda tal cual para que el bot y el equipo reclutador lo usen como referencia.</span>
          </div>

          <div class="section-divider">Textos para el bot</div>
          <div class="form-group full">
            <label for="c-desc">Descripción de la vacante</label>
            <textarea id="c-desc" name="description" placeholder="Breve descripción para mostrar al candidato…"></textarea>
          </div>
          <div class="form-group full">
            <label for="c-req">Requisitos</label>
            <textarea id="c-req" name="requirements" placeholder="Lista de requisitos…"></textarea>
          </div>
          <div class="form-group full">
            <label for="c-cond">Condiciones / beneficios</label>
            <textarea id="c-cond" name="conditions" placeholder="Salario, horario, beneficios…"></textarea>
          </div>

          <div class="section-divider">Configuración</div>
          <div class="full">
            <div class="toggle-row" id="c-toggle-row">
              <div class="toggle-row-body">
                <div class="toggle-row-title">Vacante activa</div>
                <div class="toggle-row-desc">Habilita la vacante en el sistema. El bot enruta candidatos hacia ella.</div>
              </div>
              <label class="toggle-switch" aria-label="Activar vacante">
                <input type="checkbox" id="c-isActive" onchange="syncActiveState('c-isActive','c-flow','c-toggle-row')" />
                <span class="toggle-track"></span>
              </label>
            </div>
          </div>
          <div class="full">
            <p style="font-size:12px;font-weight:600;color:var(--text-muted);margin-bottom:6px;">Flujo del bot</p>
            <div class="mode-group" id="c-flow" role="radiogroup" aria-label="Flujo del bot">
              <label class="mode-option mode-disabled">
                <input type="radio" name="c_vacancyFlow" value="apply_only" checked disabled />
                <div class="mode-option-body">
                  <div class="mode-option-title">📋 Solo postulación</div>
                  <div class="mode-option-desc">El bot recolecta datos y hoja de vida. Cierra con "quedaste registrado, te contactamos". Sin entrevista.</div>
                </div>
              </label>
              <label class="mode-option mode-disabled">
                <input type="radio" name="c_vacancyFlow" value="apply_schedule" disabled />
                <div class="mode-option-body">
                  <div class="mode-option-title">🗓️ Postulación + entrevista</div>
                  <div class="mode-option-desc">El bot recolecta datos, hoja de vida y agenda la entrevista automáticamente (candidatas femeninas siempre siguen flujo solo postulación).</div>
                </div>
              </label>
            </div>
          </div>
          <div class="schedule-config full" id="c-schedule-config">
            <div class="section-divider">Configuración de entrevista</div>
            <div class="form-group full">
              <label for="c-interviewAddress">Dirección de entrevista</label>
              <input id="c-interviewAddress" name="interviewAddress" type="text" placeholder="Ej: Carrera 80 # 12-30" />
              <span class="form-hint">Si la dejas vacía, el bot usará la zona de operación como referencia.</span>
            </div>
            <div class="form-group full">
              <label>Documentos para la entrevista</label>
              <div class="document-list" id="c-required-documents"></div>
              <div style="display:flex;justify-content:flex-start;">
                <button type="button" class="btn btn-secondary btn-sm" onclick="addRequiredDocumentField('c')">Agregar otro documento</button>
              </div>
              <span class="form-hint">Estos documentos se enviarán cuando el bot confirme la entrevista.</span>
            </div>
            <div class="form-group full">
              <label>Días disponibles para entrevista</label>
              <div class="schedule-days">
                <% const scheduleDays = [{ value: 0, label: 'Lun' }, { value: 1, label: 'Mar' }, { value: 2, label: 'Mié' }, { value: 3, label: 'Jue' }, { value: 4, label: 'Vie' }, { value: 5, label: 'Sáb' }, { value: 6, label: 'Dom' }]; %>
                <% for (const day of scheduleDays) { %>
                  <label class="schedule-day">
                    <input type="checkbox" name="slotDays" value="<%= day.value %>" />
                    <span><%= day.label %></span>
                  </label>
                <% } %>
              </div>
            </div>
            <div class="form-group">
              <label for="c-slotStartTime">Hora de entrevista</label>
              <input id="c-slotStartTime" name="slotStartTime" type="time" value="08:00" />
            </div>
            <div class="form-group">
              <label for="c-slotMaxCandidates">Candidatos por slot</label>
              <input id="c-slotMaxCandidates" name="slotMaxCandidates" type="number" min="1" max="100" value="10" />
            </div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" onclick="closeModal('modalCreate')">Cancelar</button>
        <button type="submit" class="btn btn-primary">Crear vacante</button>
      </div>
    </form>
  </div>
</div>

<!-- ── Modal Editar ── -->
<div class="modal-overlay" id="modalEdit">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modalEditTitle">
    <div class="modal-header">
      <h2 id="modalEditTitle">✏️ Editar vacante</h2>
      <button class="modal-close" onclick="closeModal('modalEdit')" aria-label="Cerrar">&times;</button>
    </div>
    <form method="post" id="formEdit" action="" onsubmit="injectConfigFields('formEdit','e-isActive','e-flow')">
      <div class="modal-body">
        <div class="form-grid">

          <div class="section-divider">Información básica</div>

          <div class="form-group full">
            <label for="e-operation">Operación / Zona</label>
            <% if (operations.length === 0) { %>
              <div class="no-ops-warn">⚠️ Sin operaciones. <a href="/admin/locations" style="color:var(--amber);font-weight:700;">Configurar →</a></div>
              <input type="hidden" name="operationId" value="" />
            <% } else { %>
            <select id="e-operation" name="operationId">
              <option value="">— Sin operación asignada —</option>
              <% let lastCityE = null; %>
              <% for (const op of operations) { %>
                <% if (op.city.name !== lastCityE) { lastCityE = op.city.name; %>
                  <optgroup label="📍 <%= op.city.name %>">
                <% } %>
                <option value="<%= op.id %>" data-city="<%= op.city.name %>" data-op="<%= op.name %>">
                  <%= op.name %>
                </option>
              <% } %>
            </select>
            <% } %>
          </div>

          <div class="form-group">
            <label for="e-title">Título <span style="color:var(--red)">*</span></label>
            <input id="e-title" name="title" type="text" required />
          </div>
          <div class="form-group">
            <label for="e-role">Rol / Cargo</label>
            <input id="e-role" name="role" type="text" />
          </div>
          <div class="form-group full">
            <label for="e-address">Zona de operación</label>
            <input id="e-address" name="operationAddress" type="text" />
          </div>

          <div class="section-divider">Edad y experiencia</div>
          <div class="form-group">
            <label for="e-minAge">Edad mínima</label>
            <input id="e-minAge" name="minAge" type="number" min="14" max="99" />
          </div>
          <div class="form-group">
            <label for="e-maxAge">Edad máxima</label>
            <input id="e-maxAge" name="maxAge" type="number" min="14" max="99" />
          </div>
          <div class="form-group full">
            <label for="e-exp">Experiencia requerida</label>
            <select id="e-exp" name="experienceRequired" onchange="syncExperienceField('e-exp', 'e-exp-time-group')">
              <option value="INDIFFERENT">Indiferente</option>
              <option value="YES">Requerida</option>
              <option value="NO">No requerida</option>
            </select>
          </div>
          <div class="form-group full" id="e-exp-time-group" style="display:none;">
            <label for="e-expTimeText">Tiempo de experiencia requerido</label>
            <input id="e-expTimeText" name="experienceTimeText" type="text" />
            <span class="form-hint">Ej: 6 meses, 1 año, coordinación de personal operativo.</span>
          </div>

          <div class="section-divider">Textos para el bot</div>
          <div class="form-group full">
            <label for="e-desc">Descripción de la vacante</label>
            <textarea id="e-desc" name="description"></textarea>
          </div>
          <div class="form-group full">
            <label for="e-req">Requisitos</label>
            <textarea id="e-req" name="requirements"></textarea>
          </div>
          <div class="form-group full">
            <label for="e-cond">Condiciones / beneficios</label>
            <textarea id="e-cond" name="conditions"></textarea>
          </div>

          <div class="section-divider">Configuración</div>
          <div class="full">
            <div class="toggle-row" id="e-toggle-row">
              <div class="toggle-row-body">
                <div class="toggle-row-title">Vacante activa</div>
                <div class="toggle-row-desc">Habilita la vacante en el sistema. El bot enruta candidatos hacia ella.</div>
              </div>
              <label class="toggle-switch" aria-label="Activar vacante">
                <input type="checkbox" id="e-isActive" onchange="syncActiveState('e-isActive','e-flow','e-toggle-row')" />
                <span class="toggle-track"></span>
              </label>
            </div>
          </div>
          <div class="full">
            <p style="font-size:12px;font-weight:600;color:var(--text-muted);margin-bottom:6px;">Flujo del bot</p>
            <div class="mode-group" id="e-flow" role="radiogroup" aria-label="Flujo del bot">
              <label class="mode-option">
                <input type="radio" name="e_vacancyFlow" value="apply_only" />
                <div class="mode-option-body">
                  <div class="mode-option-title">📋 Solo postulación</div>
                  <div class="mode-option-desc">El bot recolecta datos y hoja de vida. Cierra con "quedaste registrado, te contactamos". Sin entrevista.</div>
                </div>
              </label>
              <label class="mode-option">
                <input type="radio" name="e_vacancyFlow" value="apply_schedule" />
                <div class="mode-option-body">
                  <div class="mode-option-title">🗓️ Postulación + entrevista</div>
                  <div class="mode-option-desc">El bot recolecta datos, hoja de vida y agenda la entrevista automáticamente (candidatas femeninas siempre siguen flujo solo postulación).</div>
                </div>
              </label>
            </div>
          </div>
          <div class="schedule-config full" id="e-schedule-config">
            <div class="section-divider">Configuración de entrevista</div>
            <div class="form-group full">
              <label for="e-interviewAddress">Dirección de entrevista</label>
              <input id="e-interviewAddress" name="interviewAddress" type="text" />
              <span class="form-hint">Si la dejas vacía, el bot usará la zona de operación como referencia.</span>
            </div>
            <div class="form-group full">
              <label>Documentos para la entrevista</label>
              <div class="document-list" id="e-required-documents"></div>
              <div style="display:flex;justify-content:flex-start;">
                <button type="button" class="btn btn-secondary btn-sm" onclick="addRequiredDocumentField('e')">Agregar otro documento</button>
              </div>
              <span class="form-hint">Estos documentos se enviarán cuando el bot confirme la entrevista.</span>
            </div>
            <div class="form-group full">
              <label>Días disponibles para entrevista</label>
              <div class="schedule-days">
                <% for (const day of scheduleDays) { %>
                  <label class="schedule-day">
                    <input type="checkbox" name="slotDays" value="<%= day.value %>" />
                    <span><%= day.label %></span>
                  </label>
                <% } %>
              </div>
            </div>
            <div class="form-group">
              <label for="e-slotStartTime">Hora de entrevista</label>
              <input id="e-slotStartTime" name="slotStartTime" type="time" value="08:00" />
            </div>
            <div class="form-group">
              <label for="e-slotMaxCandidates">Candidatos por slot</label>
              <input id="e-slotMaxCandidates" name="slotMaxCandidates" type="number" min="1" max="100" value="10" />
            </div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" onclick="closeModal('modalEdit')">Cancelar</button>
        <button type="submit" class="btn btn-primary">Guardar cambios</button>
      </div>
    </form>
  </div>
</div>

<script>
  function syncScheduleConfig(checkboxId, flowGroupId, scheduleConfigId) {
    const checkbox = document.getElementById(checkboxId);
    const flowGroup = document.getElementById(flowGroupId);
    const config = document.getElementById(scheduleConfigId);
    if (!config) return;
    const flowVal = flowGroup.querySelector('input[type=radio]:checked')?.value || 'apply_only';
    const visible = checkbox.checked && flowVal === 'apply_schedule';
    config.classList.toggle('is-visible', visible);
    config.querySelectorAll('input').forEach((input) => {
      input.disabled = !visible;
    });
  }

  function syncActiveState(checkboxId, flowGroupId, toggleRowId, scheduleConfigId) {
    const checkbox  = document.getElementById(checkboxId);
    const flowGroup = document.getElementById(flowGroupId);
    const toggleRow = document.getElementById(toggleRowId);
    const isChecked = checkbox.checked;
    const radios    = flowGroup.querySelectorAll('input[type=radio]');
    const labels    = flowGroup.querySelectorAll('.mode-option');
    toggleRow.classList.toggle('is-active', isChecked);
    radios.forEach(r => r.disabled = !isChecked);
    labels.forEach(l => l.classList.toggle('mode-disabled', !isChecked));
    if (isChecked && !Array.from(radios).some(r => r.checked)) radios[0].checked = true;
    syncScheduleConfig(checkboxId, flowGroupId, scheduleConfigId);
  }

  function syncExperienceField(selectId, fieldGroupId) {
    const select = document.getElementById(selectId);
    const group = document.getElementById(fieldGroupId);
    if (!select || !group) return;
    const visible = select.value === 'YES';
    group.style.display = visible ? '' : 'none';
    const input = group.querySelector('input[name="experienceTimeText"]');
    if (input && !visible) input.value = '';
  }

  function createRequiredDocumentRow(prefix, value = '') {
    const row = document.createElement('div');
    row.className = 'document-row';

    const input = document.createElement('input');
    input.type = 'text';
    input.name = 'requiredDocuments';
    input.placeholder = 'Ej: Cédula original';
    input.value = value || '';

    const removeBtn = document.createElement('button');
    removeBtn.type = 'button';
    removeBtn.className = 'btn btn-secondary btn-sm';
    removeBtn.textContent = 'Quitar';
    removeBtn.addEventListener('click', () => {
      const container = document.getElementById(prefix + '-required-documents');
      if (!container) return;
      if (container.children.length <= 1) {
        input.value = '';
        return;
      }
      row.remove();
    });

    row.appendChild(input);
    row.appendChild(removeBtn);
    return row;
  }

  function setRequiredDocumentFields(prefix, values = []) {
    const container = document.getElementById(prefix + '-required-documents');
    if (!container) return;
    container.innerHTML = '';
    const docs = Array.isArray(values) ? values.filter(Boolean) : [];
    const source = docs.length ? docs : [''];
    source.forEach((value) => container.appendChild(createRequiredDocumentRow(prefix, value)));
  }

  function addRequiredDocumentField(prefix, value = '') {
    const container = document.getElementById(prefix + '-required-documents');
    if (!container) return;
    container.appendChild(createRequiredDocumentRow(prefix, value));
  }

  function splitRequiredDocuments(value) {
    return String(value || '')
      .split(/\r?\n/)
      .map((entry) => entry.trim())
      .filter(Boolean);
  }

  function injectConfigFields(formId, checkboxId, flowGroupId) {
    const form      = document.getElementById(formId);
    const checkbox  = document.getElementById(checkboxId);
    const flowGroup = document.getElementById(flowGroupId);
    const isActive  = checkbox.checked;
    const flowVal   = flowGroup.querySelector('input[type=radio]:checked')?.value || 'apply_only';
    const fields = {
      isActive,
      acceptingApplications: isActive,
      schedulingEnabled: isActive && flowVal === 'apply_schedule'
    };
    form.querySelectorAll('input[data-cfg-injected]').forEach(el => el.remove());
    Object.entries(fields).forEach(([name, value]) => {
      const input = document.createElement('input');
      input.type  = 'hidden'; input.name = name; input.value = value ? 'true' : '';
      input.dataset.cfgInjected = '1';
      form.appendChild(input);
    });
    return true;
  }

  function openCreate() {
    const cb = document.getElementById('c-isActive');
    cb.checked = false;
    document.getElementById('c-address').value = '';
    document.getElementById('c-interviewAddress').value = '';
    document.getElementById('c-exp').value = 'INDIFFERENT';
    document.getElementById('c-expTimeText').value = '';
    document.getElementById('c-slotStartTime').value = '08:00';
    document.getElementById('c-slotMaxCandidates').value = '10';
    document.querySelectorAll('#c-schedule-config input[name="slotDays"]').forEach((input) => { input.checked = false; });
    setRequiredDocumentFields('c');
    syncExperienceField('c-exp', 'c-exp-time-group');
    syncActiveState('c-isActive', 'c-flow', 'c-toggle-row', 'c-schedule-config');
    document.getElementById('modalCreate').classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function openEdit(v) {
    const f = document.getElementById('formEdit');
    f.action = '/admin/vacancies/' + v.id + '/edit';
    document.getElementById('e-title').value   = v.title || '';
    document.getElementById('e-role').value    = v.role  || '';
    document.getElementById('e-address').value = v.operationAddress || '';
    document.getElementById('e-interviewAddress').value = v.interviewAddress || '';
    document.getElementById('e-minAge').value  = v.minAge != null ? v.minAge : '';
    document.getElementById('e-maxAge').value  = v.maxAge != null ? v.maxAge : '';
    document.getElementById('e-exp').value     = v.experienceRequired || 'INDIFFERENT';
    document.getElementById('e-expTimeText').value = v.experienceTimeText || '';
    document.getElementById('e-desc').value    = v.roleDescription || '';
    document.getElementById('e-req').value     = v.requirements || '';
    document.getElementById('e-cond').value    = v.conditions   || '';
    setRequiredDocumentFields('e', splitRequiredDocuments(v.requiredDocuments));
    const weeklySlots = Array.isArray(v.interviewSlots)
      ? v.interviewSlots.filter((slot) => slot && slot.dayOfWeek !== null && slot.dayOfWeek !== undefined)
      : [];
    const primarySlot = weeklySlots[0] || null;
    document.getElementById('e-slotStartTime').value = primarySlot?.startTime || '08:00';
    document.getElementById('e-slotMaxCandidates').value = primarySlot?.maxCandidates || '10';
    document.querySelectorAll('#e-schedule-config input[name="slotDays"]').forEach((input) => {
      input.checked = weeklySlots.some((slot) => String(slot.dayOfWeek) === input.value);
    });

    // Seleccionar operación si existe
    const opSel = document.getElementById('e-operation');
    if (opSel && v.operationId) {
      opSel.value = v.operationId;
    } else if (opSel) {
      opSel.value = '';
    }

    const cb = document.getElementById('e-isActive');
    cb.checked = !!v.isActive;
    const flow  = v.schedulingEnabled ? 'apply_schedule' : 'apply_only';
    document.getElementById('e-flow').querySelectorAll('input[type=radio]').forEach(r => r.checked = (r.value === flow));
    syncExperienceField('e-exp', 'e-exp-time-group');
    syncActiveState('e-isActive', 'e-flow', 'e-toggle-row', 'e-schedule-config');
    document.getElementById('modalEdit').classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal(id) {
    document.getElementById(id).classList.remove('open');
    document.body.style.overflow = '';
  }

  document.querySelectorAll('.modal-overlay').forEach(overlay => {
    overlay.addEventListener('click', e => { if (e.target === overlay) closeModal(overlay.id); });
  });
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') document.querySelectorAll('.modal-overlay.open').forEach(m => closeModal(m.id));
  });
  [['c-isActive', 'c-flow', 'c-schedule-config'], ['e-isActive', 'e-flow', 'e-schedule-config']].forEach(([checkboxId, flowGroupId, configId]) => {
    const flowGroup = document.getElementById(flowGroupId);
    if (!flowGroup) return;
    flowGroup.querySelectorAll('input[type=radio]').forEach((radio) => {
      radio.addEventListener('change', () => syncScheduleConfig(checkboxId, flowGroupId, configId));
    });
  });
  ['c-exp', 'e-exp'].forEach((selectId) => {
    const select = document.getElementById(selectId);
    if (!select) return;
    select.addEventListener('change', () => syncExperienceField(selectId, selectId === 'c-exp' ? 'c-exp-time-group' : 'e-exp-time-group'));
  });
  syncExperienceField('c-exp', 'c-exp-time-group');
  syncExperienceField('e-exp', 'e-exp-time-group');
  setTimeout(() => {
    document.querySelectorAll('.alert').forEach(a => {
      a.style.transition = 'opacity .4s'; a.style.opacity = '0';
      setTimeout(() => a.remove(), 400);
    });
  }, 5000);
</script>
</body>
</html>
