<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Vacantes — LoginPro</title>
  <link rel="icon" type="image/png" href="/public/favicon-loginpro.svg" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #f4f5f7; --surface: #ffffff; --surface-2: #f9fafb;
      --border: #e1e4e8; --border-soft: #eaecef;
      --text: #1a1d23; --text-muted: #6b7280; --text-faint: #9ca3af;
      --navy: #1e2d3d; --navy-hover: #162330;
      --teal: #0d7a6b; --teal-light: #e6f4f1; --teal-hover: #0a5f53;
      --amber: #b45309; --amber-light: #fef3c7;
      --red: #dc2626; --red-light: #fee2e2;
      --gray-light: #f3f4f6; --green: #16a34a; --green-light: #dcfce7;
      --shadow-sm: 0 1px 3px rgba(0,0,0,.08); --shadow-md: 0 4px 12px rgba(0,0,0,.10);
      --radius: 8px; --radius-lg: 12px;
      --font: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }
    body { font-family: var(--font); background: var(--bg); color: var(--text); font-size: 14px; line-height: 1.5; }

    /* Navbar */
    .navbar { background: var(--navy); padding: 0 24px; display: flex; align-items: center; gap: 20px; height: 52px; position: sticky; top: 0; z-index: 100; box-shadow: 0 2px 8px rgba(0,0,0,.2); }
    .navbar a { color: #cbd5e0; text-decoration: none; font-size: 13px; font-weight: 500; padding: 4px 2px; border-bottom: 2px solid transparent; transition: color .15s, border-color .15s; }
    .navbar a:hover { color: #fff; border-bottom-color: rgba(255,255,255,.3); }
    .navbar a.active { color: #fff; border-bottom-color: var(--teal); }
    .navbar .brand img { height: 28px; display: block; }
    .navbar .spacer { flex: 1; }
    .btn-logout { background: transparent; border: 1px solid rgba(255,255,255,.25); color: #cbd5e0 !important; padding: 5px 12px !important; border-radius: 6px; cursor: pointer; font-size: 12px; font-weight: 500; transition: all .15s; }
    .btn-logout:hover { border-color: rgba(255,255,255,.6) !important; color: #fff !important; }

    /* Layout */
    .page { max-width: 1100px; margin: 0 auto; padding: 28px 20px 56px; }
    .page-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; margin-bottom: 24px; flex-wrap: wrap; }
    .page-header h1 { font-size: 20px; font-weight: 700; color: var(--navy); }
    .page-header .sub { font-size: 13px; color: var(--text-muted); margin-top: 2px; }

    /* Btn primary */
    .btn-primary {
      background: var(--teal); color: #fff; border: none; border-radius: 8px;
      padding: 9px 18px; font-size: 13px; font-weight: 600; cursor: pointer;
      text-decoration: none; display: inline-flex; align-items: center; gap: 6px;
      transition: background .15s;
    }
    .btn-primary:hover { background: var(--teal-hover); }
    .btn-secondary {
      background: var(--surface); color: var(--navy); border: 1px solid var(--border);
      border-radius: 8px; padding: 8px 16px; font-size: 13px; font-weight: 600;
      cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 6px;
      transition: background .15s;
    }
    .btn-secondary:hover { background: var(--gray-light); }
    .btn-danger {
      background: var(--red-light); color: var(--red); border: 1px solid #fca5a5;
      border-radius: 8px; padding: 7px 14px; font-size: 12px; font-weight: 600;
      cursor: pointer; transition: background .15s;
    }
    .btn-danger:hover { background: #fecaca; }

    /* Alerts */
    .alert {
      padding: 12px 16px; border-radius: 8px; font-size: 13px; font-weight: 500;
      margin-bottom: 20px; display: flex; align-items: center; gap: 10px;
    }
    .alert-success { background: var(--green-light); color: var(--green); border: 1px solid #86efac; }
    .alert-error   { background: var(--red-light);   color: var(--red);   border: 1px solid #fca5a5; }

    /* Vacancy card */
    .vacancies-list { display: flex; flex-direction: column; gap: 14px; }
    .vacancy-card {
      background: var(--surface); border: 1px solid var(--border);
      border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); overflow: hidden;
    }
    .vacancy-card.inactive { opacity: .65; }
    .vacancy-card-header {
      padding: 14px 18px; display: flex; align-items: center; gap: 14px;
      border-bottom: 1px solid var(--border-soft);
    }
    .vacancy-icon {
      width: 40px; height: 40px; border-radius: 10px; display: flex;
      align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0;
    }
    .vacancy-icon.active   { background: var(--teal-light); }
    .vacancy-icon.inactive { background: var(--gray-light); }
    .vacancy-icon.closed   { background: var(--red-light); }
    .vacancy-info { flex: 1; min-width: 0; }
    .vacancy-title { font-size: 15px; font-weight: 700; color: var(--navy); }
    .vacancy-sub   { font-size: 12px; color: var(--text-muted); margin-top: 2px; }
    .vacancy-actions { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }

    /* Badge */
    .badge {
      display: inline-flex; align-items: center; gap: 4px;
      padding: 3px 9px; border-radius: 20px; font-size: 11px; font-weight: 700;
      white-space: nowrap;
    }
    .badge-active   { background: var(--green-light); color: var(--green); }
    .badge-inactive { background: var(--gray-light);  color: var(--text-muted); }
    .badge-closed   { background: var(--red-light);   color: var(--red); }
    .badge-cv-only  { background: var(--amber-light); color: var(--amber); }
    .badge-scheduling { background: var(--teal-light); color: var(--teal); }

    /* Vacancy details grid */
    .vacancy-details {
      padding: 14px 18px; display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 12px 24px;
    }
    .detail-item .label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .05em; color: var(--text-faint); margin-bottom: 3px; }
    .detail-item .value { font-size: 13px; color: var(--text); }
    .detail-item .value.empty { color: var(--text-faint); font-style: italic; }

    /* Empty state */
    .empty-state {
      text-align: center; padding: 48px 20px;
      background: var(--surface); border: 1px solid var(--border);
      border-radius: var(--radius-lg); color: var(--text-muted);
    }
    .empty-state .empty-icon { font-size: 36px; margin-bottom: 10px; }
    .empty-state h3 { font-size: 15px; font-weight: 700; color: var(--navy); margin-bottom: 6px; }
    .empty-state p  { font-size: 13px; color: var(--text-muted); margin-bottom: 18px; }

    /* Modal overlay */
    .modal-overlay {
      display: none; position: fixed; inset: 0; z-index: 200;
      background: rgba(0,0,0,.45); align-items: flex-start; justify-content: center;
      padding: 40px 16px; overflow-y: auto;
    }
    .modal-overlay.open { display: flex; }
    .modal {
      background: var(--surface); border-radius: var(--radius-lg);
      box-shadow: 0 20px 60px rgba(0,0,0,.25); width: 100%; max-width: 580px;
      padding: 28px; position: relative;
    }
    .modal-title { font-size: 17px; font-weight: 700; color: var(--navy); margin-bottom: 20px; }
    .modal-close {
      position: absolute; top: 16px; right: 16px; background: var(--gray-light);
      border: none; border-radius: 6px; width: 28px; height: 28px; cursor: pointer;
      font-size: 16px; display: flex; align-items: center; justify-content: center;
      color: var(--text-muted); transition: background .15s;
    }
    .modal-close:hover { background: var(--border); }

    /* Form */
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .form-group { display: flex; flex-direction: column; gap: 5px; }
    .form-group.span-2 { grid-column: span 2; }
    .form-group label { font-size: 12px; font-weight: 600; color: var(--text-muted); }
    .form-group input, .form-group select, .form-group textarea {
      border: 1px solid var(--border); border-radius: 7px; padding: 8px 11px;
      font-size: 13px; font-family: var(--font); color: var(--text);
      background: var(--surface-2); outline: none; transition: border-color .15s, box-shadow .15s;
    }
    .form-group input:focus, .form-group select:focus, .form-group textarea:focus {
      border-color: var(--teal); box-shadow: 0 0 0 3px rgba(13,122,107,.12);
    }
    .form-group textarea { resize: vertical; min-height: 80px; }
    .form-hint { font-size: 11px; color: var(--text-faint); margin-top: 2px; }
    .form-actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 22px; padding-top: 18px; border-top: 1px solid var(--border-soft); }
    .checkbox-row { display: flex; align-items: center; gap: 10px; }
    .checkbox-row input[type="checkbox"] { width: 16px; height: 16px; accent-color: var(--teal); cursor: pointer; }
    .checkbox-row label { font-size: 13px; color: var(--text); cursor: pointer; }

    @media (max-width: 600px) {
      .form-grid { grid-template-columns: 1fr; }
      .form-group.span-2 { grid-column: span 1; }
      .vacancy-card-header { flex-direction: column; align-items: flex-start; }
    }
  </style>
</head>
<body>

<nav class="navbar">
  <a class="brand" href="/admin" aria-label="LoginPro">
    <img src="/public/logo-loginpro.svg" alt="LoginPro" />
  </a>
  <a href="/admin">Panel</a>
  <a href="/admin/vacancies" class="active">Vacantes</a>
  <% if (role === 'dev') { %>
    <a href="/admin/monitor">Monitor</a>
  <% } %>
  <span class="spacer"></span>
  <form method="post" action="/logout">
    <button type="submit" class="btn-logout">Cerrar sesión</button>
  </form>
</nav>

<div class="page">

  <div class="page-header">
    <div>
      <h1>Gestión de Vacantes</h1>
      <p class="sub"><%= vacancies.length %> vacante<%= vacancies.length !== 1 ? 's' : '' %> registrada<%= vacancies.length !== 1 ? 's' : '' %></p>
    </div>
    <button class="btn-primary" onclick="openModal('create')" type="button">+ Nueva vacante</button>
  </div>

  <% if (successMsg) { %>
    <div class="alert alert-success">✅ <%= successMsg %></div>
  <% } %>
  <% if (errorMsg) { %>
    <div class="alert alert-error">⚠️ <%= errorMsg %></div>
  <% } %>

  <!-- Lista de vacantes -->
  <% if (vacancies.length === 0) { %>
    <div class="empty-state">
      <div class="empty-icon">📋</div>
      <h3>No hay vacantes registradas</h3>
      <p>Crea la primera vacante para que el bot empiece a recibir postulaciones.</p>
      <button class="btn-primary" onclick="openModal('create')" type="button">+ Crear primera vacante</button>
    </div>
  <% } else { %>
    <div class="vacancies-list">
      <% for (const v of vacancies) { %>
        <%
          const isActive  = v.isActive && v.acceptingApplications;
          const isPaused  = v.isActive && !v.acceptingApplications;
          const isDeleted = !v.isActive;
          let iconChar  = isDeleted ? '🔴' : (v.schedulingEnabled ? '🗓️' : '📋');
          let iconClass = isDeleted ? 'closed' : (isActive ? 'active' : 'inactive');
          let badgeLabel, badgeClass;
          if (isDeleted)     { badgeLabel = 'Inactiva';           badgeClass = 'badge-inactive'; }
          else if (isPaused) { badgeLabel = 'Cerrada (en pausa)'; badgeClass = 'badge-closed'; }
          else               { badgeLabel = 'Activa';             badgeClass = 'badge-active'; }
          let modeBadgeLabel = v.schedulingEnabled ? 'Agendando entrevistas' : 'Solo recepción HV';
          let modeBadgeClass = v.schedulingEnabled ? 'badge-scheduling' : 'badge-cv-only';
        %>
        <div class="vacancy-card <%= isActive ? '' : 'inactive' %>">
          <div class="vacancy-card-header">
            <div class="vacancy-icon <%= iconClass %>"><%= iconChar %></div>
            <div class="vacancy-info">
              <div class="vacancy-title"><%= v.title || v.role || 'Sin título' %></div>
              <div class="vacancy-sub">📍 <%= v.city || '—' %> &nbsp;·&nbsp; 🔑 <code style="font-size:11px;"><%= v.key %></code></div>
            </div>
            <div class="vacancy-actions">
              <span class="badge <%= badgeClass %>"><%= badgeLabel %></span>
              <span class="badge <%= modeBadgeClass %>"><%= modeBadgeLabel %></span>
              <button class="btn-secondary" style="font-size:12px;padding:6px 12px;" onclick="openEditModal(<%= JSON.stringify(v) %>)" type="button">✏️ Editar</button>
              <form method="post" action="/admin/vacancies/<%= v.id %>/toggle" style="margin:0;">
                <button type="submit" class="<%= isActive || isPaused ? 'btn-danger' : 'btn-secondary' %>" style="font-size:12px;padding:6px 12px;">
                  <%= isActive ? '⏸ Pausar' : (isPaused ? '▶️ Reabrir' : '✅ Activar') %>
                </button>
              </form>
            </div>
          </div>
          <div class="vacancy-details">
            <div class="detail-item">
              <div class="label">Cargo / Rol</div>
              <div class="value <%= !v.role ? 'empty' : '' %>"><%= v.role || 'No definido' %></div>
            </div>
            <div class="detail-item">
              <div class="label">Rango de edad</div>
              <div class="value"><%= (v.minAge || '—') %> – <%= (v.maxAge || '—') %> años</div>
            </div>
            <div class="detail-item">
              <div class="label">Experiencia requerida</div>
              <div class="value"><%= v.experienceRequired || 'INDIFFERENT' %></div>
            </div>
            <div class="detail-item">
              <div class="label">Dirección operación</div>
              <div class="value <%= !v.operationAddress ? 'empty' : '' %>"><%= v.operationAddress || 'No definida' %></div>
            </div>
            <div class="detail-item span-2" style="grid-column: span 2;">
              <div class="label">Descripción</div>
              <div class="value <%= !v.description ? 'empty' : '' %>"><%= v.description || 'Sin descripción' %></div>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  <% } %>

</div>

<!-- ══════════════════════════════════════ -->
<!-- Modal: Crear vacante                  -->
<!-- ══════════════════════════════════════ -->
<div class="modal-overlay" id="modal-create">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modal-create-title">
    <button class="modal-close" onclick="closeModal('create')" type="button" aria-label="Cerrar">×</button>
    <h2 class="modal-title" id="modal-create-title">Nueva Vacante</h2>
    <form method="post" action="/admin/vacancies/create">
      <div class="form-grid">

        <div class="form-group">
          <label for="c-title">Título de la vacante *</label>
          <input type="text" id="c-title" name="title" required placeholder="Ej: Auxiliar de Cargue y Descargue" />
        </div>
        <div class="form-group">
          <label for="c-city">Ciudad *</label>
          <input type="text" id="c-city" name="city" required placeholder="Ej: Ibagué" />
        </div>

        <div class="form-group">
          <label for="c-key">Clave única (key) *</label>
          <input type="text" id="c-key" name="key" required placeholder="Ej: auxiliar-cargue-ibague" />
          <span class="form-hint">Sin espacios ni caracteres especiales. Solo letras, números y guiones.</span>
        </div>
        <div class="form-group">
          <label for="c-role">Cargo / Rol</label>
          <input type="text" id="c-role" name="role" placeholder="Ej: Auxiliar de Bodega" />
        </div>

        <div class="form-group">
          <label for="c-minAge">Edad mínima</label>
          <input type="number" id="c-minAge" name="minAge" min="16" max="99" placeholder="18" />
        </div>
        <div class="form-group">
          <label for="c-maxAge">Edad máxima</label>
          <input type="number" id="c-maxAge" name="maxAge" min="16" max="99" placeholder="50" />
        </div>

        <div class="form-group">
          <label for="c-experienceRequired">Experiencia requerida</label>
          <select id="c-experienceRequired" name="experienceRequired">
            <option value="INDIFFERENT">Indiferente</option>
            <option value="REQUIRED">Requerida</option>
            <option value="NOT_REQUIRED">No requerida</option>
          </select>
        </div>
        <div class="form-group">
          <label for="c-operationAddress">Dirección de operación</label>
          <input type="text" id="c-operationAddress" name="operationAddress" placeholder="Ej: Cll 50 #30-20 Bodega 3" />
        </div>

        <div class="form-group span-2">
          <label for="c-description">Descripción de la vacante</label>
          <textarea id="c-description" name="description" placeholder="Describe brevemente el perfil, funciones y condiciones..."></textarea>
        </div>

        <div class="form-group span-2">
          <label for="c-requirements">Requisitos</label>
          <textarea id="c-requirements" name="requirements" placeholder="Ej: Mayor de edad, buena condición física..."></textarea>
        </div>

        <div class="form-group span-2">
          <label for="c-conditions">Condiciones laborales</label>
          <textarea id="c-conditions" name="conditions" placeholder="Ej: Contrato a término fijo, salario mínimo + prestaciones..."></textarea>
        </div>

        <div class="form-group span-2" style="display:flex;flex-direction:row;gap:24px;align-items:center;flex-wrap:wrap;">
          <div class="checkbox-row">
            <input type="checkbox" id="c-isActive" name="isActive" value="true" checked />
            <label for="c-isActive">Vacante activa</label>
          </div>
          <div class="checkbox-row">
            <input type="checkbox" id="c-acceptingApplications" name="acceptingApplications" value="true" checked />
            <label for="c-acceptingApplications">Recibiendo postulaciones</label>
          </div>
          <div class="checkbox-row">
            <input type="checkbox" id="c-schedulingEnabled" name="schedulingEnabled" value="true" />
            <label for="c-schedulingEnabled">Habilitar agendamiento de entrevistas</label>
          </div>
        </div>

      </div>
      <div class="form-actions">
        <button type="button" class="btn-secondary" onclick="closeModal('create')">Cancelar</button>
        <button type="submit" class="btn-primary">Crear vacante</button>
      </div>
    </form>
  </div>
</div>

<!-- ══════════════════════════════════════ -->
<!-- Modal: Editar vacante                 -->
<!-- ══════════════════════════════════════ -->
<div class="modal-overlay" id="modal-edit">
  <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modal-edit-title">
    <button class="modal-close" onclick="closeModal('edit')" type="button" aria-label="Cerrar">×</button>
    <h2 class="modal-title" id="modal-edit-title">Editar Vacante</h2>
    <form method="post" id="edit-form" action="">
      <input type="hidden" id="e-id" name="id" />
      <div class="form-grid">

        <div class="form-group">
          <label for="e-title">Título de la vacante *</label>
          <input type="text" id="e-title" name="title" required />
        </div>
        <div class="form-group">
          <label for="e-city">Ciudad *</label>
          <input type="text" id="e-city" name="city" required />
        </div>

        <div class="form-group">
          <label for="e-key">Clave única (key) *</label>
          <input type="text" id="e-key" name="key" required />
        </div>
        <div class="form-group">
          <label for="e-role">Cargo / Rol</label>
          <input type="text" id="e-role" name="role" />
        </div>

        <div class="form-group">
          <label for="e-minAge">Edad mínima</label>
          <input type="number" id="e-minAge" name="minAge" min="16" max="99" />
        </div>
        <div class="form-group">
          <label for="e-maxAge">Edad máxima</label>
          <input type="number" id="e-maxAge" name="maxAge" min="16" max="99" />
        </div>

        <div class="form-group">
          <label for="e-experienceRequired">Experiencia requerida</label>
          <select id="e-experienceRequired" name="experienceRequired">
            <option value="INDIFFERENT">Indiferente</option>
            <option value="REQUIRED">Requerida</option>
            <option value="NOT_REQUIRED">No requerida</option>
          </select>
        </div>
        <div class="form-group">
          <label for="e-operationAddress">Dirección de operación</label>
          <input type="text" id="e-operationAddress" name="operationAddress" />
        </div>

        <div class="form-group span-2">
          <label for="e-description">Descripción de la vacante</label>
          <textarea id="e-description" name="description"></textarea>
        </div>

        <div class="form-group span-2">
          <label for="e-requirements">Requisitos</label>
          <textarea id="e-requirements" name="requirements"></textarea>
        </div>

        <div class="form-group span-2">
          <label for="e-conditions">Condiciones laborales</label>
          <textarea id="e-conditions" name="conditions"></textarea>
        </div>

        <div class="form-group span-2" style="display:flex;flex-direction:row;gap:24px;align-items:center;flex-wrap:wrap;">
          <div class="checkbox-row">
            <input type="checkbox" id="e-isActive" name="isActive" value="true" />
            <label for="e-isActive">Vacante activa</label>
          </div>
          <div class="checkbox-row">
            <input type="checkbox" id="e-acceptingApplications" name="acceptingApplications" value="true" />
            <label for="e-acceptingApplications">Recibiendo postulaciones</label>
          </div>
          <div class="checkbox-row">
            <input type="checkbox" id="e-schedulingEnabled" name="schedulingEnabled" value="true" />
            <label for="e-schedulingEnabled">Habilitar agendamiento de entrevistas</label>
          </div>
        </div>

      </div>
      <div class="form-actions">
        <button type="button" class="btn-secondary" onclick="closeModal('edit')">Cancelar</button>
        <button type="submit" class="btn-primary">Guardar cambios</button>
      </div>
    </form>
  </div>
</div>

<script>
  function openModal(type) {
    document.getElementById('modal-' + type).classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeModal(type) {
    document.getElementById('modal-' + type).classList.remove('open');
    document.body.style.overflow = '';
  }

  // Close modal clicking backdrop
  document.querySelectorAll('.modal-overlay').forEach(overlay => {
    overlay.addEventListener('click', e => {
      if (e.target === overlay) {
        overlay.classList.remove('open');
        document.body.style.overflow = '';
      }
    });
  });

  // Escape key closes modals
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape') {
      document.querySelectorAll('.modal-overlay.open').forEach(m => {
        m.classList.remove('open');
        document.body.style.overflow = '';
      });
    }
  });

  function openEditModal(v) {
    const f = document.getElementById('edit-form');
    f.action = '/admin/vacancies/' + v.id + '/edit';

    document.getElementById('e-id').value                  = v.id || '';
    document.getElementById('e-title').value               = v.title || '';
    document.getElementById('e-city').value                = v.city || '';
    document.getElementById('e-key').value                 = v.key || '';
    document.getElementById('e-role').value                = v.role || '';
    document.getElementById('e-minAge').value              = v.minAge != null ? v.minAge : '';
    document.getElementById('e-maxAge').value              = v.maxAge != null ? v.maxAge : '';
    document.getElementById('e-operationAddress').value    = v.operationAddress || '';
    document.getElementById('e-description').value         = v.description || '';
    document.getElementById('e-requirements').value        = v.requirements || '';
    document.getElementById('e-conditions').value          = v.conditions || '';
    document.getElementById('e-isActive').checked          = Boolean(v.isActive);
    document.getElementById('e-acceptingApplications').checked = Boolean(v.acceptingApplications);
    document.getElementById('e-schedulingEnabled').checked = Boolean(v.schedulingEnabled);

    const expSel = document.getElementById('e-experienceRequired');
    expSel.value = v.experienceRequired || 'INDIFFERENT';

    openModal('edit');
  }
</script>

</body>
</html>
