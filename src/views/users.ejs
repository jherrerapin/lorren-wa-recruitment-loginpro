<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Usuarios de reclutamiento | LoginPro</title>
  <link rel="icon" type="image/png" href="/public/favicon-loginpro.svg" />
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #f4f5f7; --surface: #fff; --surface-2: #f9fafb; --border: #e1e4e8;
      --text: #1a1d23; --text-muted: #6b7280; --navy: #1e2d3d; --teal: #0d7a6b;
      --teal-hover: #0a5f53; --teal-light: #e6f4f1; --red: #dc2626; --red-light: #fee2e2;
      --green: #166534; --green-light: #dcfce7; --amber: #92400e; --amber-light: #fef3c7;
      --shadow-sm: 0 1px 3px rgba(0,0,0,.08); --radius: 8px; --radius-lg: 12px;
      --font: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    }
    body { font-family: var(--font); background: var(--bg); color: var(--text); font-size: 14px; }
    .navbar { background: var(--navy); padding: 0 24px; display: flex; align-items: center; gap: 20px; height: 52px; box-shadow: 0 2px 8px rgba(0,0,0,.2); }
    .navbar a { color: #cbd5e0; text-decoration: none; font-size: 13px; font-weight: 500; padding: 4px 2px; border-bottom: 2px solid transparent; }
    .navbar a:hover { color: #fff; border-bottom-color: rgba(255,255,255,.3); }
    .navbar a.nav-active { color: #fff; border-bottom-color: #4fd1c5; }
    .navbar .brand img { height: 28px; display: block; }
    .navbar .spacer { flex: 1; }
    .btn-logout { background: transparent; border: 1px solid rgba(255,255,255,.25); color: #cbd5e0 !important; padding: 5px 12px !important; border-radius: 6px; cursor: pointer; font-size: 12px; font-weight: 500; }
    .page { max-width: 1240px; margin: 0 auto; padding: 28px 20px 60px; display: grid; gap: 18px; }
    .page-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
    .page-header h1 { font-size: 22px; color: var(--navy); }
    .page-header p { color: var(--text-muted); font-size: 13px; margin-top: 4px; }
    .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); padding: 18px; }
    .card h2 { font-size: 16px; color: var(--navy); margin-bottom: 10px; }
    .alert { padding: 12px 14px; border-radius: var(--radius); font-size: 13px; font-weight: 600; }
    .alert-success { background: var(--green-light); color: var(--green); border: 1px solid #86efac; }
    .alert-error { background: var(--red-light); color: var(--red); border: 1px solid #fca5a5; }
    .alert-info { background: #eef6ff; color: #1d4ed8; border: 1px solid #bfdbfe; }
    .grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 14px 18px; }
    .full { grid-column: 1 / -1; }
    .field { display: flex; flex-direction: column; gap: 6px; }
    .field label { font-size: 12px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: .04em; }
    .field input, .field select {
      border: 1px solid var(--border); border-radius: 8px; padding: 10px 12px; font-size: 14px;
      background: var(--surface-2); outline: none;
    }
    .field input:focus, .field select:focus { border-color: var(--teal); box-shadow: 0 0 0 3px rgba(13,122,107,.12); }
    .hint { font-size: 12px; color: var(--text-muted); }
    .actions { display: flex; gap: 10px; flex-wrap: wrap; }
    .btn { border: none; border-radius: 8px; padding: 10px 14px; cursor: pointer; font-size: 13px; font-weight: 700; }
    .btn-primary { background: var(--teal); color: #fff; }
    .btn-primary:hover { background: var(--teal-hover); }
    .btn-secondary { background: var(--surface-2); color: var(--text); border: 1px solid var(--border); }
    .btn-danger { background: var(--red-light); color: var(--red); border: 1px solid #fca5a5; }
    .btn-warning { background: var(--amber-light); color: var(--amber); border: 1px solid #fcd34d; }
    table { width: 100%; border-collapse: collapse; }
    th, td { text-align: left; padding: 12px 10px; border-bottom: 1px solid #eaecef; vertical-align: top; }
    th { font-size: 11px; text-transform: uppercase; letter-spacing: .06em; color: var(--text-muted); }
    td small { display: block; color: var(--text-muted); margin-top: 4px; }
    .badge { display: inline-flex; align-items: center; gap: 6px; padding: 4px 10px; border-radius: 999px; font-size: 11px; font-weight: 700; }
    .badge-active { background: var(--green-light); color: var(--green); }
    .badge-inactive { background: var(--red-light); color: var(--red); }
    .inline-form { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; margin-top: 8px; }
    .inline-form input { min-width: 190px; }
    .recovery-box {
      margin-top: 8px;
      padding: 12px 14px;
      border-radius: var(--radius);
      border: 1px dashed #60a5fa;
      background: #eff6ff;
      color: #1d4ed8;
      font-size: 13px;
      font-weight: 700;
    }
    .empty { padding: 24px; text-align: center; color: var(--text-muted); }
    @media (max-width: 900px) {
      .navbar {
        flex-wrap: wrap;
        height: auto;
        padding: 10px 16px;
        gap: 10px 16px;
      }
      .navbar .spacer { display: none; }
      .navbar form { width: 100%; }
      .btn-logout {
        width: 100%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }
      .page { padding: 18px 14px 42px; }
      .page-header { align-items: stretch; }
      .actions,
      .inline-form {
        flex-direction: column;
        align-items: stretch;
      }
      .inline-form input { min-width: 0; width: 100%; }
    }
    @media (max-width: 820px) {
      .grid { grid-template-columns: 1fr; }
      .full { grid-column: 1; }
      table, thead, tbody, tr, td, th { display: block; }
      thead { display: none; }
      tr { border-bottom: 1px solid #eaecef; padding: 10px 0; }
      td { border: none; padding: 8px 0; }
    }
  </style>
</head>
<body>
  <nav class="navbar">
    <a class="brand" href="/admin" aria-label="LoginPro">
      <img src="/public/logo-loginpro.svg" alt="LoginPro" />
    </a>
    <a href="/admin">Candidatos</a>
    <a href="/admin/vacancies">Vacantes</a>
    <a href="/admin/users" class="nav-active">Usuarios</a>
    <% if (role === 'dev') { %>
      <a href="/admin/monitor">Monitor</a>
    <% } %>
    <span class="spacer"></span>
    <form method="post" action="/logout">
      <button type="submit" class="btn-logout">Cerrar sesión</button>
    </form>
  </nav>

  <%
    const allowedCities = manageableScopeOptions.allowedCities || [];
    const allowedVacancies = manageableScopeOptions.allowedVacancies || [];
  %>

  <div class="page">
    <div class="page-header">
      <div>
        <h1>Usuarios de reclutamiento</h1>
        <p>Desde aquí puedes crear reclutadores con alcance total, por ciudad o por vacante, asignar contraseña inicial y regenerar su código de recuperación.</p>
      </div>
    </div>

    <% if (successMsg) { %>
      <div class="alert alert-success"><%= successMsg %></div>
    <% } %>
    <% if (errorMsg) { %>
      <div class="alert alert-error"><%= errorMsg %></div>
    <% } %>
    <% if (revealedRecoveryCode && highlightedUsername) { %>
      <div class="alert alert-info">
        Código de recuperación vigente para <strong><%= highlightedUsername %></strong>:
        <div class="recovery-box"><%= revealedRecoveryCode %></div>
      </div>
    <% } %>

    <section class="card">
      <h2>Crear usuario</h2>
      <form method="post" action="/admin/users/create">
        <div class="grid">
          <div class="field">
            <label for="accessScope">Alcance</label>
            <select id="accessScope" name="accessScope">
              <% if (manageableScopeOptions.canCreateAll) { %>
                <option value="ALL">Todas las vacantes</option>
              <% } %>
              <% if (allowedCities.length) { %>
                <option value="CITY" <%= manageableScopeOptions.canCreateAll ? '' : 'selected' %>>Solo una ciudad</option>
              <% } %>
              <% if (allowedVacancies.length) { %>
                <option value="VACANCY">Una vacante específica</option>
              <% } %>
            </select>
          </div>

          <div class="field">
            <label for="password">Contraseña inicial</label>
            <input id="password" name="password" type="password" minlength="6" required />
            <span class="hint">Mínimo 6 caracteres.</span>
          </div>

          <div class="field" id="cityField">
            <label for="scopeCity">Ciudad</label>
            <select id="scopeCity" name="scopeCity">
              <option value="">Selecciona una ciudad</option>
              <% for (const city of allowedCities) { %>
                <option value="<%= city %>"><%= city %></option>
              <% } %>
            </select>
          </div>

          <div class="field" id="vacancyField">
            <label for="scopeVacancyId">Vacante</label>
            <select id="scopeVacancyId" name="scopeVacancyId">
              <option value="">Selecciona una vacante</option>
              <% for (const vacancy of allowedVacancies) { %>
                <option value="<%= vacancy.id %>"><%= vacancy.city %> · <%= vacancy.title || vacancy.role %></option>
              <% } %>
            </select>
          </div>

          <div class="field">
            <label for="recoveryPhone">Teléfono de recuperación</label>
            <input id="recoveryPhone" name="recoveryPhone" type="text" />
          </div>

          <div class="field">
            <label for="recoveryEmail">Correo de recuperación</label>
            <input id="recoveryEmail" name="recoveryEmail" type="email" />
          </div>

          <div class="full actions">
            <button class="btn btn-primary" type="submit">Crear usuario</button>
          </div>
        </div>
      </form>
      <p class="hint" style="margin-top:12px;">El username se genera automáticamente como <strong>reclutador-...</strong>. Si ya existe, el sistema agrega un consecutivo.</p>
    </section>

    <section class="card">
      <h2>Usuarios creados</h2>
      <% if (!users.length) { %>
        <div class="empty">Todavía no hay usuarios creados en base de datos para este alcance.</div>
      <% } else { %>
        <table>
          <thead>
            <tr>
              <th>Usuario</th>
              <th>Alcance</th>
              <th>Estado</th>
              <th>Recuperación</th>
              <th>Acciones</th>
            </tr>
          </thead>
          <tbody>
            <% for (const user of users) { %>
              <tr>
                <td>
                  <strong><%= user.username %></strong>
                  <% if (user.username === highlightedUsername) { %><small>Último usuario intervenido</small><% } %>
                  <small>Creado por: <%= user.createdByUsername || 'Sistema' %></small>
                </td>
                <td>
                  <%= describeUserScope(user) %>
                  <% if (user.scopeVacancy?.city) { %><small>Ciudad operativa: <%= user.scopeVacancy.city %></small><% } %>
                </td>
                <td>
                  <span class="badge <%= user.isActive ? 'badge-active' : 'badge-inactive' %>">
                    <%= user.isActive ? 'Activo' : 'Inactivo' %>
                  </span>
                  <small>Último cambio de contraseña: <%= user.lastPasswordResetAt ? user.lastPasswordResetAt.toLocaleString('es-CO', { hour12: false }) : 'Sin registro' %></small>
                </td>
                <td>
                  <small>Tel: <%= user.recoveryPhone || '—' %></small>
                  <small>Correo: <%= user.recoveryEmail || '—' %></small>
                  <small>El usuario puede recuperar acceso desde /recover con el código vigente.</small>
                </td>
                <td>
                  <form method="post" action="/admin/users/<%= user.id %>/toggle" class="inline-form">
                    <button type="submit" class="btn <%= user.isActive ? 'btn-danger' : 'btn-secondary' %>">
                      <%= user.isActive ? 'Desactivar' : 'Activar' %>
                    </button>
                  </form>
                  <form method="post" action="/admin/users/<%= user.id %>/reset-recovery-code" class="inline-form">
                    <button type="submit" class="btn btn-warning">Regenerar código</button>
                  </form>
                  <form method="post" action="/admin/users/<%= user.id %>/reset-password" class="inline-form">
                    <input name="newPassword" type="password" minlength="6" placeholder="Nueva contraseña" required />
                    <button type="submit" class="btn btn-secondary">Resetear contraseña</button>
                  </form>
                </td>
              </tr>
            <% } %>
          </tbody>
        </table>
      <% } %>
    </section>
  </div>

  <script>
    (function () {
      const accessScope = document.getElementById('accessScope');
      const cityField = document.getElementById('cityField');
      const vacancyField = document.getElementById('vacancyField');

      function syncScopeVisibility() {
        const scope = accessScope ? accessScope.value : 'ALL';
        if (cityField) cityField.style.display = scope === 'CITY' ? 'flex' : 'none';
        if (vacancyField) vacancyField.style.display = scope === 'VACANCY' ? 'flex' : 'none';
      }

      if (accessScope) {
        accessScope.addEventListener('change', syncScopeVisibility);
        syncScopeVisibility();
      }
    })();
  </script>
</body>
</html>
