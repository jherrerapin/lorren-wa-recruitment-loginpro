/// Genera el cliente de Prisma para que la aplicación pueda consultar y escribir en la base de datos.
generator client {
  /// Define el proveedor oficial del cliente Prisma para JavaScript/Node.js.
  provider = "prisma-client-js"
}

/// Define la conexión principal a la base de datos relacional.
datasource db {
  /// Indica que el motor de base de datos es PostgreSQL.
  provider = "postgresql"
  /// Toma la cadena de conexión desde la variable de entorno DATABASE_URL.
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// ENUMS
// ---------------------------------------------------------------------------

/// Enumera los estados permitidos para cada candidato dentro del flujo operativo.
enum CandidateStatus {
  /// Estado inicial cuando el candidato apenas entra al flujo.
  NUEVO
  /// Estado cuando el candidato completó registro de datos.
  REGISTRADO
  /// Estado operativo para revisión interna del reclutador.
  VALIDANDO
  /// Estado final positivo del flujo.
  APROBADO
  /// Estado final negativo del flujo.
  RECHAZADO
  /// Estado para candidatos que ya fueron contactados por el equipo.
  CONTACTADO
}

/// Enumera cada paso del flujo conversacional simplificado.
enum ConversationStep {
  /// Menú principal — el candidato aún no ha escrito.
  MENU
  /// Se envió el saludo con la información de la vacante.
  GREETING_SENT
  /// Se están capturando los datos del candidato de forma natural.
  COLLECTING_DATA
  /// Se están confirmando los datos con el candidato antes de guardar.
  CONFIRMING_DATA
  /// Se pregunta opcionalmente por hoja de vida después de registrar.
  ASK_CV
  /// Se está ofreciendo y agendando entrevista (solo cuando requiresInterview=true).
  SCHEDULING_INTERVIEW
  /// Flujo completado — el candidato ya está registrado.
  DONE
}

/// Enumera la dirección de cada mensaje persistido.
enum MessageDirection {
  /// Mensaje entrante desde WhatsApp hacia el sistema.
  INBOUND
  /// Mensaje saliente desde el sistema hacia WhatsApp.
  OUTBOUND
}

/// Enumera los tipos de mensaje que vamos a persistir para auditoría operativa.
enum MessageType {
  /// Mensaje de texto.
  TEXT
  /// Mensaje con documento adjunto.
  DOCUMENT
  /// Mensaje de imagen.
  IMAGE
  /// Mensaje interactivo.
  INTERACTIVE
  /// Mensaje no soportado por el flujo contingente.
  UNKNOWN
}

/// Enumera el estado del recordatorio automático por inactividad.
enum ReminderState {
  /// No hay recordatorio aplicado.
  NONE
  /// Recordatorio programado pendiente de envío.
  SCHEDULED
  /// Recordatorio enviado al candidato.
  SENT
  /// Recordatorio cancelado por nueva actividad inbound.
  CANCELLED
  /// Recordatorio omitido por política/ventana/estado.
  SKIPPED
}

/// Enumera los estados posibles de una entrevista agendada.
enum InterviewStatus {
  /// Entrevista agendada, pendiente de confirmación.
  SCHEDULED
  /// Candidato confirmó asistencia vía WhatsApp.
  CONFIRMED
  /// Candidato canceló o indicó que no va a asistir.
  CANCELLED
  /// Candidato solicitó reprogramar.
  RESCHEDULED
  /// Candidato no se presentó (marcado manualmente por reclutador).
  NO_SHOW
  /// Candidato asistió a la entrevista (marcado manualmente).
  ATTENDED
}

/// Respuesta del candidato al recordatorio 1h antes de la entrevista.
enum ReminderResponse {
  /// Candidato confirmó asistencia.
  CONFIRMED
  /// Candidato canceló.
  CANCELLED
  /// Candidato solicitó reprogramar.
  RESCHEDULED
  /// No hubo respuesta dentro de la ventana.
  NO_RESPONSE
}

// ---------------------------------------------------------------------------
// MODELOS PRINCIPALES
// ---------------------------------------------------------------------------

/// Modelo principal de candidato.
model Candidate {
  /// Identificador único interno del candidato.
  id                     String            @id @default(cuid())
  /// Número de teléfono del candidato, único por registro.
  phone                  String            @unique
  /// Nombre completo capturado por el bot.
  fullName               String?
  /// Tipo de documento del candidato (CC, TI, CE, pasaporte, etc.).
  documentType           String?
  /// Número de documento del candidato.
  documentNumber         String?
  /// Edad del candidato.
  age                    Int?
  /// Ciudad del candidato.
  city                   String?
  /// Barrio del candidato en el flujo actual.
  neighborhood           String?
  /// Localidad o municipio del candidato (aplica cuando la vacante tiene requiresLocality=true).
  locality               String?
  /// Resultado de la validación geográfica por IA: true=viable, false=no viable, null=no evaluado.
  proximityOk            Boolean?
  /// Barrio o localidad del candidato (campo legado).
  zone                   String?
  /// Indica si cuenta con experiencia en el cargo.
  experienceInfo         String?
  /// Tiempo de experiencia reportado por el candidato.
  experienceTime         String?
  /// Restricciones médicas reportadas por el candidato.
  medicalRestrictions    String?
  /// Medio de transporte del candidato.
  transportMode          String?
  /// Último motivo de rechazo aplicado al candidato.
  rejectionReason        String?
  /// Detalles adicionales del rechazo para trazabilidad.
  rejectionDetails       String?
  /// Resumen de experiencia del candidato (campo legado, no se usa en el flujo actual).
  experienceSummary      String?
  /// Disponibilidad horaria del candidato (campo legado, no se usa en el flujo actual).
  availability           String?
  /// Estado actual del candidato en el proceso.
  status                 CandidateStatus   @default(NUEVO)
  /// Paso actual del flujo conversacional.
  currentStep            ConversationStep  @default(MENU)
  /// Nombre original del archivo de hoja de vida (campo legado, no se usa en el flujo actual).
  cvOriginalName         String?
  /// Tipo MIME del archivo de hoja de vida (campo legado, no se usa en el flujo actual).
  cvMimeType             String?
  /// Binario de la hoja de vida (campo legado, no se usa en el flujo actual).
  cvData                 Bytes?
  /// Fecha de creación automática del registro.
  createdAt              DateTime          @default(now())
  /// Fecha de actualización automática del registro.
  updatedAt              DateTime          @updatedAt
  /// Fin de la ventana de silencio para consolidar mensajes de texto.
  multilineWindowUntil   DateTime?
  /// Versión incremental para controlar carreras del batching multilinea.
  multilineBatchVersion  Int               @default(0)
  /// Fecha del último inbound recibido para control de ventana y recordatorios.
  lastInboundAt          DateTime?
  /// Fecha del último outbound enviado para trazabilidad.
  lastOutboundAt         DateTime?
  /// Fecha del último recordatorio de inactividad enviado.
  lastReminderAt         DateTime?
  /// Fecha objetivo para envío del recordatorio de inactividad.
  reminderScheduledFor   DateTime?
  /// Estado del ciclo de recordatorio de inactividad.
  reminderState          ReminderState     @default(NONE)
  /// Permite pausar manualmente las respuestas automáticas del bot para este candidato.
  botPaused              Boolean           @default(false)
  /// Fecha y hora en la que se aplicó la pausa manual.
  botPausedAt            DateTime?
  /// Usuario/rol que aplicó la pausa manual.
  botPausedBy            String?
  /// Motivo opcional registrado para la pausa manual.
  botPauseReason         String?
  /// Modo de reanudación aplicado por operación humana.
  botResumeMode          String?
  /// Marca si existe potencial de duplicado documental con otro teléfono.
  potentialDuplicate     Boolean           @default(false)
  /// Referencia textual del candidato potencialmente duplicado.
  potentialDuplicateNote String?
  /// Fecha en que se detectó el potencial duplicado documental.
  potentialDuplicateAt   DateTime?
  /// Relación uno a muchos con los mensajes del candidato.
  messages               Message[]
  /// Vacante asociada al candidato dentro del flujo de conversación.
  vacancyId              String?
  /// Relación opcional con la vacante detectada/asignada para el candidato.
  vacancy                Vacancy?          @relation(fields: [vacancyId], references: [id], onDelete: SetNull)
  /// Entrevistas agendadas para este candidato.
  interviews             Interview[]
}

/// Modelo de auditoría de mensajes.
model Message {
  /// Identificador único interno del mensaje.
  id          String           @id @default(cuid())
  /// Llave foránea hacia el candidato dueño del mensaje.
  candidateId String
  /// Relación hacia el candidato asociado al mensaje.
  candidate   Candidate        @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  /// Identificador del mensaje en WhatsApp para idempotencia.
  waMessageId String?          @unique
  /// Dirección del mensaje.
  direction   MessageDirection
  /// Tipo del mensaje.
  messageType MessageType
  /// Cuerpo textual persistido del mensaje.
  body        String?
  /// Payload crudo completo recibido o generado.
  rawPayload  Json?
  /// Fecha en la que este inbound fue consolidado y respondido.
  respondedAt DateTime?
  /// Fecha de creación automática del mensaje.
  createdAt   DateTime         @default(now())

  /// Índice para acelerar consultas por candidato y fecha.
  @@index([candidateId, createdAt])
}

/// Catálogo base de vacantes configurables para el flujo conversacional.
model Vacancy {
  /// Identificador único interno de la vacante.
  id                   String          @id @default(cuid())
  /// Clave técnica única de vacante usada por detección y automatización.
  key                  String          @unique
  /// Título comercial de la vacante (ej. "Auxiliar de Cargue y Descargue").
  title                String
  /// Nombre del cargo específico (ej. "Auxiliar logístico").
  cargo                String?
  /// Ciudad principal de la operación.
  city                 String
  /// Dirección exacta del lugar de trabajo u operación.
  operationAddress     String?
  /// Zonas o localidades viables para candidatos (JSON array de strings).
  /// Solo se usa cuando requiresLocality = true.
  /// Ejemplo: ["Suba", "Engativá", "Funza", "Mosquera"]
  operationZones       Json?
  /// Descripción general de la vacante.
  description          String?
  /// Perfil buscado para la vacante.
  profile              String?
  /// Salario o rango salarial de la vacante.
  salary               String?
  /// Horario de trabajo (ej. "Turnos rotativos 6am-2pm / 2pm-10pm").
  schedule             String?
  /// Tipo de contrato (ej. "Obra labor", "Término fijo", "Indefinido").
  contractType         String?
  /// Mensaje de introducción que usa el bot en el saludo dinámico.
  botIntroText         String?
  /// Resumen corto de requisitos para respuesta inicial del bot.
  requirementsSummary  String?
  /// Imagen publicitaria principal asociada a la vacante.
  adImageData          Bytes?
  /// Tipo MIME de la imagen publicitaria.
  adImageMimeType      String?
  /// Nombre original del archivo de imagen publicitaria.
  adImageOriginalName  String?
  /// Pistas textuales del anuncio para mejorar clasificación semántica.
  adTextHints          String?
  /// Alias semánticos para detección de cargo (JSON array o string simple).
  aliases              Json?
  /// Configuración de screening reservada para evolución futura.
  screeningConfig      Json?
  /// Switch: si true, el bot pedirá localidad/municipio al candidato y evaluará proximidad.
  requiresLocality     Boolean         @default(false)
  /// Switch: si true, el bot agendará entrevistas después de recolectar datos y HV.
  /// Si false, el bot solo recibe datos y HV, y cierra con mensaje de "te contactaremos".
  requiresInterview    Boolean         @default(false)
  /// Define si la vacante está activa para selección automática.
  isActive             Boolean         @default(true)
  /// Orden de despliegue en dashboard y fallback operativo.
  displayOrder         Int             @default(0)
  /// Fecha de creación automática.
  createdAt            DateTime        @default(now())
  /// Fecha de actualización automática.
  updatedAt            DateTime        @updatedAt
  /// Relación inversa de candidatos asociados a esta vacante.
  candidates           Candidate[]
  /// Slots de entrevista configurados para esta vacante (solo cuando requiresInterview=true).
  interviewSlots       InterviewSlot[]
}

// ---------------------------------------------------------------------------
// MODELOS DE ENTREVISTAS
// ---------------------------------------------------------------------------

/// Bloque de tiempo disponible para entrevistas de una vacante.
/// Configurado por el reclutador o dev desde el dashboard.
model InterviewSlot {
  /// Identificador único del slot.
  id           String      @id @default(cuid())
  /// Vacante a la que pertenece este slot.
  vacancyId    String
  vacancy      Vacancy     @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  /// Fecha y hora exacta del slot (ej. 2026-04-07T10:00:00).
  /// Se usa fecha concreta, no día de semana, para mayor control operativo.
  scheduledAt  DateTime
  /// Capacidad máxima de candidatos para este slot.
  maxCapacity  Int         @default(1)
  /// Candidatos ya agendados en este slot (calculado vía relación).
  interviews   Interview[]
  /// Si el slot está disponible para agendamiento.
  isActive     Boolean     @default(true)
  /// Fecha de creación.
  createdAt    DateTime    @default(now())

  @@index([vacancyId, scheduledAt])
}

/// Entrevista agendada para un candidato en un slot específico.
model Interview {
  /// Identificador único de la entrevista.
  id                 String           @id @default(cuid())
  /// Candidato citado.
  candidateId        String
  candidate          Candidate        @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  /// Slot de entrevista asignado.
  slotId             String
  slot               InterviewSlot    @relation(fields: [slotId], references: [id], onDelete: Cascade)
  /// Estado actual de la entrevista.
  status             InterviewStatus  @default(SCHEDULED)
  /// Fecha y hora en que se confirmó o actualizó el estado.
  statusUpdatedAt    DateTime?
  /// Usuario o sistema que actualizó el estado.
  statusUpdatedBy    String?
  /// Fecha y hora en que se envió el recordatorio 1h antes.
  reminderSentAt     DateTime?
  /// Respuesta del candidato al recordatorio (si la hubo dentro de la ventana).
  reminderResponse   ReminderResponse?
  /// Notas internas del reclutador sobre esta entrevista.
  notes              String?
  /// Fecha de creación.
  createdAt          DateTime         @default(now())
  /// Fecha de actualización.
  updatedAt          DateTime         @updatedAt

  @@index([candidateId])
  @@index([slotId])
}
