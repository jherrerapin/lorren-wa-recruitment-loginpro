/// Genera el cliente de Prisma para que la aplicación pueda consultar y escribir en la base de datos.
generator client {
  /// Define el proveedor oficial del cliente Prisma para JavaScript/Node.js.
  provider = "prisma-client-js"
}

/// Define la conexión principal a la base de datos relacional.
datasource db {
  /// Indica que el motor de base de datos es PostgreSQL.
  provider = "postgresql"
  /// Toma la cadena de conexión desde la variable de entorno DATABASE_URL.
  url      = env("DATABASE_URL")
}

/// Enumera los estados permitidos para cada candidato dentro del flujo operativo.
enum CandidateStatus {
  /// Estado inicial cuando el candidato apenas entra al flujo.
  NUEVO
  /// Estado cuando el candidato completó registro de datos.
  REGISTRADO
  /// Estado operativo para revisión interna del reclutador.
  VALIDANDO
  /// Estado final positivo del flujo.
  APROBADO
  /// Estado final negativo del flujo.
  RECHAZADO
  /// Estado para candidatos que ya fueron contactados por el equipo.
  CONTACTADO
}

/// Enumera cada paso del flujo conversacional simplificado.
enum ConversationStep {
  /// Menú principal — el candidato aún no ha escrito.
  MENU
  /// Se envió el saludo con la información de la vacante.
  GREETING_SENT
  /// Se están capturando los datos del candidato de forma natural.
  COLLECTING_DATA
  /// Se están confirmando los datos con el candidato antes de guardar.
  CONFIRMING_DATA
  /// Se pregunta opcionalmente por hoja de vida después de registrar.
  ASK_CV
  /// Flujo completado — el candidato ya está registrado.
  DONE
}

/// Enumera la dirección de cada mensaje persistido.
enum MessageDirection {
  /// Mensaje entrante desde WhatsApp hacia el sistema.
  INBOUND
  /// Mensaje saliente desde el sistema hacia WhatsApp.
  OUTBOUND
}

/// Enumera los tipos de mensaje que vamos a persistir para auditoría operativa.
enum MessageType {
  /// Mensaje de texto.
  TEXT
  /// Mensaje con documento adjunto.
  DOCUMENT
  /// Mensaje interactivo.
  INTERACTIVE
  /// Mensaje no soportado por el flujo contingente.
  UNKNOWN
}

/// Enumera el estado del recordatorio automático por inactividad.
enum ReminderState {
  /// No hay recordatorio aplicado.
  NONE
  /// Recordatorio programado pendiente de envío.
  SCHEDULED
  /// Recordatorio enviado al candidato.
  SENT
  /// Recordatorio cancelado por nueva actividad inbound.
  CANCELLED
  /// Recordatorio omitido por política/ventana/estado.
  SKIPPED
}

/// Modelo principal de candidato.
model Candidate {
  /// Identificador único interno del candidato.
  id                String            @id @default(cuid())
  /// Número de teléfono del candidato, único por registro.
  phone             String            @unique
  /// Nombre completo capturado por el bot.
  fullName          String?
  /// Tipo de documento del candidato (CC, TI, CE, pasaporte, etc.).
  documentType      String?
  /// Número de documento del candidato.
  documentNumber    String?
  /// Edad del candidato.
  age               Int?
  /// Ciudad del candidato.
  city              String?
  /// Barrio del candidato en el flujo actual.
  neighborhood      String?
  /// Barrio o localidad del candidato (campo legado).
  zone              String?
  /// Indica si cuenta con experiencia en el cargo.
  experienceInfo    String?
  /// Tiempo de experiencia reportado por el candidato.
  experienceTime    String?
  /// Restricciones médicas reportadas por el candidato.
  medicalRestrictions String?
  /// Medio de transporte del candidato.
  transportMode     String?
  /// Último motivo de rechazo aplicado al candidato.
  rejectionReason   String?
  /// Detalles adicionales del rechazo para trazabilidad.
  rejectionDetails  String?
  /// Resumen de experiencia del candidato (campo legado, no se usa en el flujo actual).
  experienceSummary String?
  /// Disponibilidad horaria del candidato (campo legado, no se usa en el flujo actual).
  availability      String?
  /// Estado actual del candidato en el proceso.
  status            CandidateStatus   @default(NUEVO)
  /// Paso actual del flujo conversacional.
  currentStep       ConversationStep  @default(MENU)
  /// Nombre original del archivo de hoja de vida (campo legado, no se usa en el flujo actual).
  cvOriginalName    String?
  /// Tipo MIME del archivo de hoja de vida (campo legado, no se usa en el flujo actual).
  cvMimeType        String?
  /// Binario de la hoja de vida (campo legado, no se usa en el flujo actual).
  cvData            Bytes?
  /// Fecha de creación automática del registro.
  createdAt         DateTime          @default(now())
  /// Fecha de actualización automática del registro.
  updatedAt         DateTime          @updatedAt
  /// Fin de la ventana de silencio para consolidar mensajes de texto.
  multilineWindowUntil DateTime?
  /// Versión incremental para controlar carreras del batching multilinea.
  multilineBatchVersion Int          @default(0)
  /// Fecha del último inbound recibido para control de ventana y recordatorios.
  lastInboundAt     DateTime?
  /// Fecha del último outbound enviado para trazabilidad.
  lastOutboundAt    DateTime?
  /// Fecha del último recordatorio enviado.
  lastReminderAt    DateTime?
  /// Fecha objetivo para envío del recordatorio automático.
  reminderScheduledFor DateTime?
  /// Estado del ciclo de recordatorio de inactividad.
  reminderState     ReminderState    @default(NONE)
  /// Permite pausar manualmente las respuestas automáticas del bot para este candidato.
  botPaused         Boolean          @default(false)
  /// Fecha y hora en la que se aplicó la pausa manual.
  botPausedAt       DateTime?
  /// Usuario/rol que aplicó la pausa manual.
  botPausedBy       String?
  /// Motivo opcional registrado para la pausa manual.
  botPauseReason    String?
  /// Modo de reanudación aplicado por operación humana.
  botResumeMode     String?
  /// Marca si existe potencial de duplicado documental con otro teléfono.
  potentialDuplicate Boolean         @default(false)
  /// Referencia textual del candidato potencialmente duplicado.
  potentialDuplicateNote String?
  /// Fecha en que se detectó el potencial duplicado documental.
  potentialDuplicateAt DateTime?
  /// Relación uno a muchos con los mensajes del candidato.
  messages          Message[]
}

/// Modelo de auditoría de mensajes.
model Message {
  /// Identificador único interno del mensaje.
  id          String           @id @default(cuid())
  /// Llave foránea hacia el candidato dueño del mensaje.
  candidateId String
  /// Relación hacia el candidato asociado al mensaje.
  candidate   Candidate        @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  /// Identificador del mensaje en WhatsApp para idempotencia.
  waMessageId String?          @unique
  /// Dirección del mensaje.
  direction   MessageDirection
  /// Tipo del mensaje.
  messageType MessageType
  /// Cuerpo textual persistido del mensaje.
  body        String?
  /// Payload crudo completo recibido o generado.
  rawPayload  Json?
  /// Fecha en la que este inbound fue consolidado y respondido.
  respondedAt DateTime?
  /// Fecha de creación automática del mensaje.
  createdAt   DateTime         @default(now())

  /// Índice para acelerar consultas por candidato y fecha.
  @@index([candidateId, createdAt])
}
