generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum CandidateStatus {
  NUEVO
  REGISTRADO
  VALIDANDO
  APROBADO
  RECHAZADO
  CONTACTADO
}

enum ConversationStep {
  MENU
  GREETING_SENT
  COLLECTING_DATA
  CONFIRMING_DATA
  ASK_CV
  DONE
  SCHEDULING
  SCHEDULED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageType {
  TEXT
  DOCUMENT
  IMAGE
  INTERACTIVE
  UNKNOWN
}

enum ReminderState {
  NONE
  SCHEDULED
  SENT
  CANCELLED
  SKIPPED
}

enum Gender {
  MALE
  FEMALE
  OTHER
  UNKNOWN
}

enum ExperienceRequirement {
  YES
  NO
  INDIFFERENT
}

enum BookingStatus {
  SCHEDULED
  CONFIRMED
  RESCHEDULED
  NO_SHOW
  CANCELLED
}

// ─────────────────────────────────────────────
// CITY — nivel 1 de la jerarquía geográfica
// ─────────────────────────────────────────────

/// Ciudad operativa (ej: Bogotá, Ibagué).
model City {
  id         String      @id @default(cuid())
  name       String      @unique
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  operations Operation[]
}

// ─────────────────────────────────────────────
// OPERATION — nivel 2: zona/operación dentro de una ciudad
// ─────────────────────────────────────────────

/// Operación o zona dentro de una ciudad (ej: Siberia, Montevideo, Sur).
model Operation {
  id        String    @id @default(cuid())
  name      String
  cityId    String
  city      City      @relation(fields: [cityId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  vacancies Vacancy[]

  @@unique([name, cityId])
}

// ─────────────────────────────────────────────
// VACANCY — vacante configurable desde el dashboard
// ─────────────────────────────────────────────

/// Vacante de reclutamiento configurable por el equipo de LoginPro.
model Vacancy {
  id                     String                @id @default(cuid())
  title                  String
  key                    String                @unique
  role                   String
  roleDescription        String?
  /// Ciudad (string) — se deriva automáticamente de operation.city.name al crear/editar.
  city                   String
  operationAddress       String
  interviewAddress       String?
  requirements           String
  conditions             String
  requiredDocuments      String?
  minAge                 Int?
  maxAge                 Int?
  experienceRequired     ExperienceRequirement @default(INDIFFERENT)
  experienceTimeText     String?
  minExperienceMonths    Int?
  maxExperienceMonths    Int?
  imageData              Bytes?
  imageMimeType          String?
  zoneFilterEnabled      Boolean               @default(false)
  zoneContext            String?
  schedulingEnabled      Boolean               @default(false)
  acceptingApplications  Boolean               @default(true)
  /// Si la vacante está activa en el sistema (visible para el bot).
  isActive               Boolean               @default(true)
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt

  /// Operación a la que pertenece esta vacante (FK hacia nivel 2).
  operationId            String?
  operation              Operation?            @relation(fields: [operationId], references: [id], onDelete: SetNull)

  candidates             Candidate[]
  interviewSlots         InterviewSlot[]
  interviewBookings      InterviewBooking[]
}

// ─────────────────────────────────────────────
// INTERVIEW SLOT
// ─────────────────────────────────────────────

model InterviewSlot {
  id                   String    @id @default(cuid())
  vacancyId            String
  vacancy              Vacancy   @relation(fields: [vacancyId], references: [id])
  dayOfWeek            Int?
  specificDate         DateTime?
  startTime            String
  maxCandidates        Int       @default(10)
  isActive             Boolean   @default(true)
  createdAt            DateTime  @default(now())

  bookings             InterviewBooking[]
}

// ─────────────────────────────────────────────
// INTERVIEW BOOKING
// ─────────────────────────────────────────────

model InterviewBooking {
  id                    String        @id @default(cuid())
  candidateId           String
  candidate             Candidate     @relation(fields: [candidateId], references: [id])
  vacancyId             String
  vacancy               Vacancy       @relation(fields: [vacancyId], references: [id])
  slotId                String
  slot                  InterviewSlot @relation(fields: [slotId], references: [id])
  scheduledAt           DateTime
  status                BookingStatus @default(SCHEDULED)
  reminderSentAt        DateTime?
  reminderWindowClosed  Boolean       @default(false)
  reminderResponse      String?
  notes                 String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

// ─────────────────────────────────────────────
// CANDIDATE
// ─────────────────────────────────────────────

model Candidate {
  id                       String            @id @default(cuid())
  phone                    String            @unique

  vacancyId                String?
  vacancy                  Vacancy?          @relation(fields: [vacancyId], references: [id])

  fullName                 String?
  documentType             String?
  documentNumber           String?
  age                      Int?
  gender                   Gender            @default(UNKNOWN)
  neighborhood             String?
  locality                 String?
  zoneViable               Boolean?

  experienceInfo           String?
  experienceTime           String?
  medicalRestrictions      String?
  transportMode            String?

  rejectionReason          String?
  rejectionDetails         String?

  zone                     String?
  experienceSummary        String?
  availability             String?

  status                   CandidateStatus   @default(NUEVO)
  currentStep              ConversationStep  @default(MENU)

  cvOriginalName           String?
  cvMimeType               String?
  cvData                   Bytes?

  multilineWindowUntil     DateTime?
  multilineBatchVersion    Int               @default(0)

  lastInboundAt            DateTime?
  lastOutboundAt           DateTime?
  devLastSeenAt            DateTime?
  lastReminderAt           DateTime?
  reminderScheduledFor     DateTime?
  reminderState            ReminderState     @default(NONE)

  botPaused                Boolean           @default(false)
  botPausedAt              DateTime?
  botPausedBy              String?
  botPauseReason           String?
  botResumeMode            String?

  potentialDuplicate       Boolean           @default(false)
  potentialDuplicateAt     DateTime?
  potentialDuplicateNote   String?

  interviewNotes           String?

  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt

  messages                 Message[]
  interviewBookings        InterviewBooking[]
}

// ─────────────────────────────────────────────
// MESSAGE
// ─────────────────────────────────────────────

model Message {
  id           String           @id @default(cuid())
  candidateId  String
  candidate    Candidate        @relation(fields: [candidateId], references: [id])
  waMessageId  String?          @unique
  direction    MessageDirection
  messageType  MessageType
  body         String?
  rawPayload   Json?
  respondedAt  DateTime?
  createdAt    DateTime         @default(now())
}
