# ─── WhatsApp Business API ────────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# ─── Base de datos ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/loginpro_contingency

# ─── Redis (requerido en producción para sesiones persistentes y lock distribuido)
# Sin esta variable el sistema usa MemoryStore (solo aceptable en desarrollo local)
REDIS_URL=redis://localhost:6379

# ─── Sesiones ────────────────────────────────────────────────────────────────
# Genera un secreto robusto: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=
SESSION_COOKIE_NAME=loginpro.sid

# ─── Autenticación del dashboard ─────────────────────────────────────────────
DEV_USER=
DEV_PASS=
ADMIN_USER=
ADMIN_PASS=

# ─── Cloudflare R2 (CVs) ─────────────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ─── Rate limiting (opcional, valores por defecto mostrados) ─────────────────
# Máximo de requests al webhook por IP por minuto (default: 60)
RATE_LIMIT_WEBHOOK_MAX=60
# Máximo de intentos de login por IP en 15 minutos (default: 10)
RATE_LIMIT_LOGIN_MAX=10

# ─── Servidor ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
