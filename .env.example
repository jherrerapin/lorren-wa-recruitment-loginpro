PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/loginpro_contingency?schema=public
META_VERIFY_TOKEN=pon_este_mismo_valor_en_meta
META_ACCESS_TOKEN=pega_tu_access_token_permanente
META_PHONE_NUMBER_ID=pega_tu_phone_number_id
APP_BASE_URL=https://tu-dominio-api.com
ADMIN_USER=reclutador
ADMIN_PASS=cambia-esta-clave-ya
DEV_USER=desarrollador
DEV_PASS=cambia-esta-clave-dev
R2_ACCOUNT_ID=tu_account_id
R2_ACCESS_KEY_ID=tu_access_key_id
R2_SECRET_ACCESS_KEY=tu_secret_access_key
R2_BUCKET=loginpro-recruitment-cv-contingency
R2_PUBLIC_BASE_URL=
R2_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com

# OpenAI
# Modelo recomendado: gpt-5-nano (bajo costo, suficiente para flujo conversacional)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5-nano
OPENAI_ENABLED=true
OPENAI_TIMEOUT_MS=14000
OPENAI_MIN_FIELD_CONFIDENCE=0.7
OPENAI_MIN_INTENT_CONFIDENCE=0.7

# Sesiones
# SESSION_SECRET debe ser un string aleatorio largo y seguro en producción.
# Genera uno con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=cambia-este-secreto
SESSION_COOKIE_NAME=loginpro.sid

# Redis (usado para sesiones persistentes en producción)
# En desarrollo puede omitirse; el sistema usará PostgreSQL como store.
REDIS_URL=redis://localhost:6379
